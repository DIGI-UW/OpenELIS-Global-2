{
  "_comment": "OpenELIS Global 2 - Menu Seed Configuration Example",
  "_description": "This file defines menu entries to be created in the database at application startup when org.openelisglobal.menu.seed.enabled=true",
  "_usage": [
    "1. Copy this file to /var/lib/openelis-global/menu/menu_seed.json",
    "2. Customize menu entries for your implementation",
    "3. Enable seeding by setting org.openelisglobal.menu.seed.enabled=true in application.properties",
    "4. Restart the application - menus will be created if they don't exist",
    "5. Existing menus are preserved (idempotent)"
  ],
  "_notes": [
    "elementId: Unique identifier (required) - used to check if menu already exists",
    "displayKey: i18n key for menu label (required)",
    "toolTipKey: i18n key for tooltip (optional)",
    "actionURL: URL or path to navigate to (optional)",
    "clickAction: JavaScript action (optional)",
    "presentationOrder: Sort order - lower numbers appear first (required)",
    "isActive: Initial visibility (default: true)",
    "openInNewWindow: Open link in new window (default: false)",
    "hideInOldUI: Hide in legacy UI (default: false)",
    "childMenus: Array of child menu definitions (optional)"
  ],
  "menus": [
    {
      "elementId": "menu_home",
      "displayKey": "banner.menu.home",
      "toolTipKey": "banner.menu.home.tooltip",
      "actionURL": "/Dashboard",
      "presentationOrder": 1,
      "isActive": true,
      "openInNewWindow": false,
      "hideInOldUI": false
    },
    {
