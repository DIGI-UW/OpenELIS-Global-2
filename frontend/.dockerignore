# Dependencies — installed fresh inside the build via `npm ci` from the
# committed package-lock.json. Copying the host's node_modules/ overwrites
# the deterministic install with whatever stale tree the dev had locally
# (e.g. pre-Vite-migration sass 1.58.3 missing initAsyncCompiler).
node_modules
.npm
.pnpm-store

# Build outputs — regenerated by the build stage. `build/` is a leftover
# from the Create React App era; `dist/` is the current Vite output.
build
dist
.vite

# Test + report artifacts
coverage
test-results
playwright-report
blob-report
playwright/.auth

# Editor / OS / VCS noise that doesn't belong in the image
.git
.gitignore
.vscode
.idea
.DS_Store
*.log
*.swp
current_failures.txt

# Local env (image consumers wire env via compose/runtime, not bake-time)
.env
.env.*
!.env.example
