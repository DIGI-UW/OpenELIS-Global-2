# frontend/Dockerfile.dev
#
# Source-mounted HMR container for active frontend editing. Extends the
# shared base — adds only a dev-server entrypoint. Not used by CI or the
# harness (those run the prod Dockerfile for ship-what-you-test parity).
#
# Build:
#   # first pre-build the base
#   docker build -f frontend/Dockerfile.base -t openelis-frontend-base:local frontend/
#   # then the dev image
#   docker build -f frontend/Dockerfile.dev -t openelis-frontend-dev:local frontend/
#
# Use via docker-compose.override.yml (or a dedicated dev compose file) that
# mounts ../frontend/src and ../frontend/public into /app/src and /app/public
# so Vite's file watcher picks up host edits.
#
# Serves plain HTTP on :3000. TLS is terminated at the outer proxy (same
# contract as the prod image). Do NOT set HTTPS=true here — vite-plugin-basic-ssl
# is documented as dev-browser-only and doesn't handshake cleanly with nginx
# upstream.

FROM openelis-frontend-base:local

EXPOSE 3000
CMD ["npm", "start"]
