# Copy this file to .env for local development.

# LLM (LM Studio) configuration
LLM_BASE_URL=http://localhost:1234
LLM_MODEL=local-model

# Ports
GATEWAY_PORT=8000
ROUTER_PORT=9100
CATALYST_AGENT_PORT=9101
MCP_PORT=9102

# A2A endpoint URLs (Router -> Catalyst)
CATALYST_ROUTER_URL=http://localhost:9100
CATALYST_AGENT_URL=http://localhost:9101

# MCP endpoint URL (Catalyst -> MCP)
MCP_URL=http://localhost:9102
