#!/bin/bash
# Auto-format hook: Runs formatters on staged files before commit
# This prevents CI failures from formatting issues

set -e

echo "🎨 Running auto-formatters..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Track if we need to re-stage files
NEEDS_RESTAGE=false

# Format Java files (Maven Spotless)
if echo "$STAGED_FILES" | grep -q '\.java$'; then
    echo "  → Formatting Java files (spotless)..."
    mvn spotless:apply -q 2>/dev/null || true
    NEEDS_RESTAGE=true
fi

# Format frontend files (npm)
if echo "$STAGED_FILES" | grep -qE 'frontend/.*\.(js|jsx|ts|tsx|css|scss)$'; then
    echo "  → Formatting frontend files (prettier)..."
    (cd frontend && npm run format --silent 2>/dev/null) || true
    NEEDS_RESTAGE=true
fi

# Format Python files (Ruff) in catalyst
if echo "$STAGED_FILES" | grep -qE 'projects/catalyst/.*\.py$'; then
    echo "  → Formatting Python files (ruff)..."
    (cd projects/catalyst/catalyst-agents && uv run ruff format . 2>/dev/null) || true
    (cd projects/catalyst/catalyst-gateway && uv run ruff format . 2>/dev/null) || true
    (cd projects/catalyst/catalyst-mcp && uv run ruff format . 2>/dev/null) || true
    NEEDS_RESTAGE=true
fi

# Re-stage files if formatting changed anything
if [ "$NEEDS_RESTAGE" = true ]; then
    echo "  → Re-staging formatted files..."
    echo "$STAGED_FILES" | while IFS= read -r file; do
        if [ -f "$file" ]; then
            git add "$file"
        fi
    done
fi

echo "✅ Formatting complete!"
exit 0
