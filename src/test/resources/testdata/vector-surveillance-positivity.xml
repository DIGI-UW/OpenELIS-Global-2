<!-- Reference rows for VectorSurveillancePositivityIntegrationTest. The
    analysis / result / test_result rows are inserted via jdbcTemplate in the
    test (FlatXmlDataSet column-sensing cannot mix a pool-anchored analysis (vector_pool_id)
    and an item-anchored analysis (sampitem_id) reliably, and we want explicit
    control over significance per result). Scenario (collection_date 2026-07-06,
    ISO week): * Anopheles gambiae, Yersinia-pestis-style pathogen "Malaria Parasite
    Detection" (test 900) + CSP/sporozoite assay "Pan-Plasmodium CSP ELISA" (test
    901). * Pool 900 (sample 900): CONFIRMED-NEGATIVE. deconvolution_status COMPLETE,
    its pathogen result carries significance=NEGATIVE. THE INVERSION GUARD: old
    code marked this POSITIVE (status != NOT_APPLICABLE); new code must not.
    * Pool 901 (sample 901): POSITIVE. pathogen result significance=POSITIVE,
    deconvolution_status COMPLETE (resolved). One member deconvoluted to an individual
    positive sampleItem (903) for the decon-aware count. * Pool 902 (sample 902):
    Anopheles, CSP-ELISA POSITIVE (sporozoite guard). * Site 900 vs 901: pool
    900/901/902 members collect at site 900; an extra Culex pool 903 (sample
    903) collects at site 901 (site-filter guard). -->
<dataset>
    <localization id="900" description="VSPosLoc" />
    <localization_value id="900" localization_id="900"
        locale="en" value="Mosquito" />
    <supported_locale id="900" locale_code="en"
        display_name="English" is_active="true" is_fallback="true"
        sort_order="1" />

    <status_of_sample id="900" name="SampleEntered"
        status_type="SAMPLE" code="1" description="entered"
        display_key="status.sample.entered" is_active="Y"
        lastupdated="2026-07-06 00:00:00" />

    <type_of_sample id="900" description="Mosquito"
        domain="V" local_abbrev="mosq" is_active="true" sort_order="1"
        name_localization_id="900" display_key="sample.type.Mosquito"
        lastupdated="2026-07-06 00:00:00" />

    <organization id="900" name="Vector Lab" short_name="VL"
        local_abbrev="vlab" code="VL900" lastupdated="2026-07-06 00:00:00" />
    <test_section id="900" name="V-04"
