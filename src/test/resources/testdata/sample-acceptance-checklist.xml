    <dictionary id="4" is_active="Y" dict_entry="volumeAdequate"
        local_Abbrev="Sample volume adequate" dictionary_category_id="1"
        sort_order="3" lastUpdated="2026-01-01 12:00:00" />
    <dictionary id="3" is_active="Y" dict_entry="coldChain"
        local_Abbrev="Cold chain maintained" dictionary_category_id="1"
        sort_order="4" lastUpdated="2026-01-01 12:00:00" />
    <dictionary id="2" is_active="Y" dict_entry="transit"
        local_Abbrev="Acceptable transit time / condition"
        dictionary_category_id="1" sort_order="5"
        lastUpdated="2026-01-01 12:00:00" />
    <dictionary id="1" is_active="Y" dict_entry="paperwork"
        local_Abbrev="Required paperwork present and complete"
        dictionary_category_id="1" sort_order="6"
        lastUpdated="2026-01-01 12:00:00" />

    <!-- QA item (different category) -->
    <dictionary id="7" is_active="Y"
        dict_entry="patientInfoVerified"
        local_Abbrev="Patient information is correct"
        dictionary_category_id="5" sort_order="1"
        lastUpdated="2026-01-01 12:00:00" />

</dataset>
