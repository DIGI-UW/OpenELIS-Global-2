<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="audit-log-001-make-user-nullable" author="claude">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="inventory_audit_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Make performed_by_user nullable to support test scenarios and system operations</comment>

        <!-- Drop the foreign key constraint first -->
        <dropForeignKeyConstraint baseTableName="inventory_audit_log"
                                 constraintName="fk_audit_user"
                                 baseTableSchemaName="clinlims"/>

        <!-- Make the column nullable -->
        <dropNotNullConstraint tableName="inventory_audit_log"
                              columnName="performed_by_user"
                              columnDataType="INTEGER"
                              schemaName="clinlims"/>

        <!-- Re-add the foreign key constraint but without NOT NULL requirement -->
        <addForeignKeyConstraint constraintName="fk_audit_user"
                                baseTableName="inventory_audit_log"
                                baseColumnNames="performed_by_user"
                                baseTableSchemaName="clinlims"
                                referencedTableName="system_user"
                                referencedColumnNames="id"
                                referencedTableSchemaName="clinlims"
                                onDelete="RESTRICT"
                                onUpdate="RESTRICT"/>
    </changeSet>

</databaseChangeLog>
