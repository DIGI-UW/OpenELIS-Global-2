    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <property name="now" value="now()" dbms="postgresql" />

    <changeSet author="codex" id="1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">select count(*) from clinlims.site_information_domain where name = 'labNumberManagement';</sqlCheck>
        </preConditions>
        <comment>ensure labNumberManagement domain exists for lab number regex settings</comment>
        <insert schemaName="clinlims" tableName="site_information_domain">
            <column name="id" valueSequenceNext="site_information_domain_seq" />
            <column name="name" value="labNumberManagement" />
            <column name="description" value="Items related to lab numbers" />
        </insert>
    </changeSet>

    <changeSet author="codex" id="2">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">select count(*) from clinlims.site_information where name = 'alphanumAccessionRegex';</sqlCheck>
        </preConditions>
        <comment>add alphanum accession regex configuration</comment>
        <insert schemaName="clinlims" tableName="site_information">
            <column name="id" valueSequenceNext="site_information_seq" />
            <column name="name" value="alphanumAccessionRegex" />
            <column name="lastupdated" valueComputed="${now}" />
            <column name="description" value="regex for alphanumeric accession numbers" />
            <column name="encrypted" value="false" />
            <column name="domain_id" valueComputed="(SELECT id FROM site_information_domain WHERE name = 'labNumberManagement')" />
            <column name="value_type" value="text" />
            <column name="group" value="0" />
        </insert>
    </changeSet>

