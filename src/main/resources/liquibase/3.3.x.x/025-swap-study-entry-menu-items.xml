    <!-- Add Reception role access for React Study Initial Entry -->
    <changeSet author="sagar" id="add-study-initial-entry-react-role-7">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.system_role WHERE name = 'Reception'
            </sqlCheck>
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.system_module WHERE name = 'StudyInitialEntryReact'
            </sqlCheck>
        </preConditions>
        <comment
        >Add Reception role access for React Study Initial Entry</comment>
        <insert tableName="system_module_url" schemaName="clinlims">
            <column name="id" valueSequenceNext="system_module_url_seq" />
            <column name="url_path" value="/StudyInitialEntry" />
            <column
                name="system_module_id"
                valueComputed="(SELECT id FROM clinlims.system_module WHERE name = 'StudyInitialEntryReact')"
            />
        </insert>
        <insert tableName="system_role_module" schemaName="clinlims">
            <column name="id" valueSequenceNext="system_role_module_seq" />
            <column name="has_select" value="Y" />
            <column name="has_add" value="Y" />
            <column name="has_update" value="Y" />
            <column
                name="system_role_id"
                valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'Reception')"
            />
            <column
                name="system_module_id"
                valueComputed="(SELECT id FROM clinlims.system_module WHERE name = 'StudyInitialEntryReact')"
            />
        </insert>
    </changeSet>

