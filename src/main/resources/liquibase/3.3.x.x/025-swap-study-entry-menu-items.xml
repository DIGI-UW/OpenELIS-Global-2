    <!-- Add system module for React Study Initial Entry -->
    <changeSet
        author="sagar"
        id="add-study-initial-entry-react-system-module-5"
    >
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.system_module WHERE name = 'StudyInitialEntryReact'
            </sqlCheck>
        </preConditions>
        <comment>Add system module for React Study Initial Entry</comment>
        <insert tableName="system_module" schemaName="clinlims">
            <column name="id" valueSequenceNext="system_module_seq" />
            <column name="name" value="StudyInitialEntryReact" />
            <column
                name="description"
                value="React implementation of Study Initial Entry"
            />
            <column name="has_select_flag" value="Y" />
            <column name="has_add_flag" value="Y" />
            <column name="has_update_flag" value="Y" />
            <column name="has_delete_flag" value="Y" />
        </insert>
    </changeSet>

