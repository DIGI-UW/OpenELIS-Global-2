<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd"
>

    <!-- Hide old Study Initial Entry menu from React UI -->
    <changeSet author="sagar" id="hide-old-study-initial-entry-in-new-ui-1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.menu
                WHERE element_id = 'menu_sample_create_initial'
            </sqlCheck>
        </preConditions>
        <comment>Hide old Study Initial Entry menu from React UI</comment>
        <update tableName="menu" schemaName="clinlims">
            <column name="hide_in_new_ui" valueBoolean="true" />
            <where>element_id = 'menu_sample_create_initial'</where>
        </update>
    </changeSet>

    <!-- Hide old Study Double Entry menu from React UI -->
    <changeSet author="sagar" id="hide-old-study-double-entry-in-new-ui-2">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.menu
                WHERE element_id = 'menu_sample_create_double'
            </sqlCheck>
        </preConditions>
        <comment>Hide old Study Double Entry menu from React UI</comment>
        <update tableName="menu" schemaName="clinlims">
            <column name="hide_in_new_ui" valueBoolean="true" />
            <where>element_id = 'menu_sample_create_double'</where>
        </update>
    </changeSet>

    <!-- Add new React Study Initial Entry menu item -->
    <changeSet author="sagar" id="add-study-initial-entry-react-menu-3">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_study_initial_entry_react'
            </sqlCheck>
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_sample_create'
            </sqlCheck>
        </preConditions>
        <comment
        >Adds Study Initial Entry React menu item under Order->Study menu (hidden from old UI)</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column
                name="parent_id"
                valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_sample_create')"
            />
            <column name="presentation_order" value="1" />
            <column name="element_id" value="menu_study_initial_entry_react" />
            <column name="action_url" value="/StudyInitialEntry" />
            <column name="display_key" value="banner.menu.createInitial" />
            <column
                name="tool_tip_key"
                value="tooltip.banner.menu.createInitial"
            />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

