<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="analyzer-006-add-has-setup-page" author="jpa-migration">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="analyzer" columnName="has_setup_page"/>
            </not>
        </preConditions>
        <comment>Add has_setup_page to analyzer so entity matches schema (2.3 analyzer_experiment may not run in 3.3 path)</comment>
        <addColumn tableName="analyzer">
            <column name="has_setup_page" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
