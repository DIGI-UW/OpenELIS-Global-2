<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Hierarchy Traversal Indexes (Parent Lookups) -->
    <changeSet id="storage-015-create-hierarchy-indexes" author="sample-storage-feature">
        <createIndex indexName="idx_device_parent_room" tableName="storage_device">
            <column name="parent_room_id"/>
        </createIndex>
        <createIndex indexName="idx_shelf_parent_device" tableName="storage_shelf">
            <column name="parent_device_id"/>
        </createIndex>
        <createIndex indexName="idx_rack_parent_shelf" tableName="storage_rack">
            <column name="parent_shelf_id"/>
        </createIndex>
        <createIndex indexName="idx_position_parent_rack" tableName="storage_position">
            <column name="parent_rack_id"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_device_parent_room" tableName="storage_device"/>
            <dropIndex indexName="idx_shelf_parent_device" tableName="storage_shelf"/>
            <dropIndex indexName="idx_rack_parent_shelf" tableName="storage_rack"/>
            <dropIndex indexName="idx_position_parent_rack" tableName="storage_position"/>
        </rollback>
    </changeSet>

    <!-- FHIR UUID Lookup Indexes -->
    <changeSet id="storage-016-create-fhir-uuid-indexes" author="sample-storage-feature">
        <createIndex indexName="idx_room_fhir_uuid" tableName="storage_room">
            <column name="fhir_uuid"/>
        </createIndex>
        <createIndex indexName="idx_device_fhir_uuid" tableName="storage_device">
            <column name="fhir_uuid"/>
        </createIndex>
        <createIndex indexName="idx_shelf_fhir_uuid" tableName="storage_shelf">
            <column name="fhir_uuid"/>
        </createIndex>
        <createIndex indexName="idx_rack_fhir_uuid" tableName="storage_rack">
            <column name="fhir_uuid"/>
        </createIndex>
        <createIndex indexName="idx_position_fhir_uuid" tableName="storage_position">
            <column name="fhir_uuid"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_room_fhir_uuid" tableName="storage_room"/>
            <dropIndex indexName="idx_device_fhir_uuid" tableName="storage_device"/>
            <dropIndex indexName="idx_shelf_fhir_uuid" tableName="storage_shelf"/>
            <dropIndex indexName="idx_rack_fhir_uuid" tableName="storage_rack"/>
            <dropIndex indexName="idx_position_fhir_uuid" tableName="storage_position"/>
        </rollback>
    </changeSet>

    <!-- Sample Assignment Lookup Indexes -->
    <changeSet id="storage-017-create-assignment-indexes" author="sample-storage-feature">
        <createIndex indexName="idx_assignment_sample" tableName="sample_storage_assignment">
            <column name="sample_id"/>
        </createIndex>
        <createIndex indexName="idx_assignment_position" tableName="sample_storage_assignment">
            <column name="storage_position_id"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_assignment_sample" tableName="sample_storage_assignment"/>
            <dropIndex indexName="idx_assignment_position" tableName="sample_storage_assignment"/>
        </rollback>
    </changeSet>

    <!-- Movement Audit Query Indexes -->
    <changeSet id="storage-018-create-movement-indexes" author="sample-storage-feature">
        <createIndex indexName="idx_movement_sample" tableName="sample_storage_movement">
            <column name="sample_id"/>
        </createIndex>
        <createIndex indexName="idx_movement_date" tableName="sample_storage_movement">
            <column name="movement_date" descending="true"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_movement_sample" tableName="sample_storage_movement"/>
            <dropIndex indexName="idx_movement_date" tableName="sample_storage_movement"/>
        </rollback>
    </changeSet>

    <!-- Active Status Filter Indexes -->
    <changeSet id="storage-019-create-active-status-indexes" author="sample-storage-feature">
        <createIndex indexName="idx_room_active" tableName="storage_room">
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_device_active" tableName="storage_device">
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_shelf_active" tableName="storage_shelf">
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_rack_active" tableName="storage_rack">
            <column name="active"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_room_active" tableName="storage_room"/>
            <dropIndex indexName="idx_device_active" tableName="storage_device"/>
            <dropIndex indexName="idx_shelf_active" tableName="storage_shelf"/>
            <dropIndex indexName="idx_rack_active" tableName="storage_rack"/>
        </rollback>
    </changeSet>

    <!-- Position Occupancy Query Index -->
    <changeSet id="storage-020-create-position-occupancy-index" author="sample-storage-feature">
        <createIndex indexName="idx_position_occupied" tableName="storage_position">
            <column name="parent_rack_id"/>
            <column name="occupied"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_position_occupied" tableName="storage_position"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

