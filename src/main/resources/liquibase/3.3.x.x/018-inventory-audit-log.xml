<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="inventory-audit-001-create-audit-log-table" author="mherman22">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="inventory_audit_log" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create immutable audit log table for inventory operations</comment>

        <createTable tableName="inventory_audit_log" schemaName="clinlims">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="timestamp" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="performed_by_user" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="operation_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <!-- ITEM_CREATE, ITEM_UPDATE, ITEM_DEACTIVATE,
                 LOT_RECEIVE, LOT_OPEN, LOT_QC_UPDATE, LOT_ADJUST, LOT_DISPOSE,
                 USAGE_RECORD, LOCATION_CREATE, LOCATION_UPDATE, etc. -->

            <!-- Entity References -->
            <column name="entity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <!-- ITEM, LOT, LOCATION, USAGE, TRANSACTION -->

            <column name="entity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <!-- Related Entity (for compound operations) -->
            <column name="related_entity_type" type="VARCHAR(50)"/>
            <column name="related_entity_id" type="BIGINT"/>

            <!-- Before/After State (JSON for flexibility) -->
            <column name="before_state" type="TEXT"/>
            <column name="after_state" type="TEXT"/>

            <!-- Operation Details -->
            <column name="operation_details" type="TEXT"/>
            <!-- Structured JSON with operation-specific data:
                 - reason (for adjustments, disposals)
                 - notes (for QC status, adjustments)
                 - quantity_changed (for usage, adjustments)
                 - old_value / new_value (for specific field changes)
                 etc. -->

            <!-- Searchable Fields (denormalized for query performance) -->
            <column name="item_id" type="BIGINT"/>
            <column name="item_name" type="VARCHAR(255)"/>
            <column name="lot_id" type="BIGINT"/>
            <column name="lot_number" type="VARCHAR(100)"/>
            <column name="location_id" type="BIGINT"/>
        </createTable>

        <addDefaultValue tableName="inventory_audit_log"
                        columnName="timestamp"
                        defaultValueComputed="CURRENT_TIMESTAMP"/>
    </changeSet>

    <changeSet id="inventory-audit-002-create-sequence" author="mherman22">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="inventory_audit_log_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sequence for inventory_audit_log primary keys</comment>

        <createSequence sequenceName="inventory_audit_log_seq"
                       schemaName="clinlims"
                       startValue="1"
                       incrementBy="1"/>
    </changeSet>

    <changeSet id="inventory-audit-003-create-indexes" author="claude">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="inventory_audit_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Create indexes for efficient querying of audit logs</comment>

        <!-- Entity lookup -->
        <createIndex indexName="idx_audit_entity"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>

        <!-- Time-based queries -->
        <createIndex indexName="idx_audit_timestamp"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="timestamp"/>
        </createIndex>

        <!-- User activity queries -->
        <createIndex indexName="idx_audit_user"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="performed_by_user"/>
        </createIndex>

        <!-- Operation type queries -->
        <createIndex indexName="idx_audit_operation"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="operation_type"/>
        </createIndex>

        <!-- Item-specific queries (denormalized for performance) -->
        <createIndex indexName="idx_audit_item"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="item_id"/>
        </createIndex>

        <!-- Lot-specific queries (denormalized for performance) -->
        <createIndex indexName="idx_audit_lot"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="lot_id"/>
        </createIndex>

        <!-- Location-specific queries -->
        <createIndex indexName="idx_audit_location"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="location_id"/>
        </createIndex>

        <!-- Composite index for item audit trail -->
        <createIndex indexName="idx_audit_item_timeline"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="item_id"/>
            <column name="timestamp"/>
        </createIndex>

        <!-- Composite index for lot audit trail -->
        <createIndex indexName="idx_audit_lot_timeline"
                    tableName="inventory_audit_log"
                    schemaName="clinlims">
            <column name="lot_id"/>
            <column name="timestamp"/>
        </createIndex>
    </changeSet>

    <changeSet id="inventory-audit-004-add-foreign-keys" author="claude">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="inventory_audit_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Add foreign key constraints for referential integrity</comment>

        <!-- FK to system_user -->
        <addForeignKeyConstraint constraintName="fk_audit_user"
                                baseTableName="inventory_audit_log"
                                baseColumnNames="performed_by_user"
                                baseTableSchemaName="clinlims"
                                referencedTableName="system_user"
                                referencedColumnNames="id"
                                referencedTableSchemaName="clinlims"
                                onDelete="RESTRICT"
                                onUpdate="RESTRICT"/>
    </changeSet>

    <changeSet id="inventory-audit-005-add-table-comment" author="mherman22">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="inventory_audit_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Add table and column comments for documentation</comment>

        <sql>
            COMMENT ON TABLE clinlims.inventory_audit_log IS
            'Immutable audit trail for all inventory management operations.
            Records all changes with full before/after state and operation details.
            Pattern: Insert-only, never UPDATE or DELETE.';
        </sql>

        <sql>
            COMMENT ON COLUMN clinlims.inventory_audit_log.operation_type IS
            'Type of operation performed. Examples: ITEM_CREATE, ITEM_UPDATE, ITEM_DEACTIVATE,
            LOT_RECEIVE, LOT_OPEN, LOT_QC_UPDATE, LOT_ADJUST, LOT_DISPOSE, USAGE_RECORD';
        </sql>

        <sql>
            COMMENT ON COLUMN clinlims.inventory_audit_log.before_state IS
            'JSON snapshot of entity state before the operation. NULL for CREATE operations.';
        </sql>

        <sql>
            COMMENT ON COLUMN clinlims.inventory_audit_log.after_state IS
            'JSON snapshot of entity state after the operation. NULL for DELETE operations.';
        </sql>

        <sql>
            COMMENT ON COLUMN clinlims.inventory_audit_log.operation_details IS
            'JSON object with operation-specific details like reason, notes, quantity changes, etc.';
        </sql>
    </changeSet>

    <changeSet id="inventory-audit-log-add-last-updated-002" author="mherman22">
        <comment>Add last_updated column to inventory_audit_log table</comment>
        <addColumn tableName="inventory_audit_log" schemaName="clinlims">
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="inventory-audit-003-drop-sys-user-id" author="mherman22">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="inventory_audit_log" columnName="sys_user_id" schemaName="clinlims"/>
        </preConditions>
        <comment>Drop sys_user_id column - redundant with performed_by_user column</comment>
        <dropColumn tableName="inventory_audit_log" columnName="sys_user_id" schemaName="clinlims"/>
    </changeSet>

</databaseChangeLog>
