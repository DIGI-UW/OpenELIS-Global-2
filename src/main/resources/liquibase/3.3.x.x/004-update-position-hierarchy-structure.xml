<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Update Storage Position Table to Support Flexible Hierarchy (2-5 Levels) -->
    <!-- T026d: Add parent_device_id, parent_shelf_id, make parent_rack_id and coordinate nullable -->
    <changeSet id="storage-011-update-position-hierarchy-structure" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="storage_position"/>
            <not>
                <columnExists tableName="storage_position" columnName="parent_device_id"/>
            </not>
        </preConditions>

        <!-- Step 1: Add parent_shelf_id column (nullable) -->
        <addColumn tableName="storage_position">
            <column name="parent_shelf_id" type="numeric(10,0)">
                <constraints nullable="true" foreignKeyName="fk_position_shelf"
                    references="storage_shelf(id)" deleteCascade="true"/>
            </column>
        </addColumn>

        <!-- Step 2: Add parent_device_id column (nullable first for data migration) -->
        <addColumn tableName="storage_position">
            <column name="parent_device_id" type="numeric(10,0)">
                <constraints nullable="true" foreignKeyName="fk_position_device"
                    references="storage_device(id)" deleteCascade="true"/>
            </column>
        </addColumn>

        <!-- Step 3: Migrate existing data - populate parent_device_id from existing hierarchy -->
        <!-- For existing positions: parent_device_id = parent_rack.parent_shelf.parent_device -->
        <sql>
            UPDATE storage_position sp
            SET parent_device_id = (
                SELECT sd.id
                FROM storage_rack sr
                JOIN storage_shelf ss ON sr.parent_shelf_id = ss.id
                JOIN storage_device sd ON ss.parent_device_id = sd.id
                WHERE sr.id = sp.parent_rack_id
            )
            WHERE sp.parent_rack_id IS NOT NULL
                AND sp.parent_device_id IS NULL;
        </sql>

        <!-- Step 4: Migrate existing data - populate parent_shelf_id from existing hierarchy -->
        <!-- For existing positions: parent_shelf_id = parent_rack.parent_shelf -->
        <sql>
            UPDATE storage_position sp
            SET parent_shelf_id = (
                SELECT ss.id
                FROM storage_rack sr
                JOIN storage_shelf ss ON sr.parent_shelf_id = ss.id
                WHERE sr.id = sp.parent_rack_id
            )
            WHERE sp.parent_rack_id IS NOT NULL
                AND sp.parent_shelf_id IS NULL;
        </sql>

        <!-- Step 5: Ensure all existing positions have parent_device_id (should not be needed, but safety check) -->
        <!-- This handles edge cases where migration didn't set parent_device_id -->
        <sql>
            -- Only update if there are positions without parent_device_id
            -- This should not happen if migration worked correctly
            UPDATE storage_position
            SET parent_device_id = (
                SELECT id FROM storage_device ORDER BY id LIMIT 1
            )
            WHERE parent_device_id IS NULL
                AND EXISTS (SELECT 1 FROM storage_device);
        </sql>

        <!-- Step 6: Make parent_device_id NOT NULL -->
        <addNotNullConstraint tableName="storage_position" columnName="parent_device_id" columnDataType="numeric(10,0)"/>

        <!-- Step 7: Make parent_rack_id nullable (change from NOT NULL to NULL) -->
        <dropNotNullConstraint tableName="storage_position" columnName="parent_rack_id" columnDataType="numeric(10,0)"/>

        <!-- Step 8: Make coordinate nullable (change from NOT NULL to NULL) -->
        <dropNotNullConstraint tableName="storage_position" columnName="coordinate" columnDataType="VARCHAR(50)"/>

        <!-- Step 9: Add CHECK constraint: If parent_rack_id is NOT NULL, then parent_shelf_id must also be NOT NULL -->
        <sql>
            ALTER TABLE storage_position
            ADD CONSTRAINT chk_position_rack_requires_shelf
            CHECK (
                (parent_rack_id IS NULL) OR (parent_shelf_id IS NOT NULL)
            );
        </sql>

        <!-- Step 10: Add CHECK constraint: If coordinate is NOT NULL, then parent_rack_id must also be NOT NULL -->
        <sql>
            ALTER TABLE storage_position
            ADD CONSTRAINT chk_position_coordinate_requires_rack
            CHECK (
                (coordinate IS NULL) OR (parent_rack_id IS NOT NULL)
            );
        </sql>

        <!-- Step 11: Add index on parent_device_id for performance -->
        <createIndex tableName="storage_position" indexName="idx_position_parent_device">
            <column name="parent_device_id"/>
        </createIndex>

        <rollback>
            <!-- Rollback: Remove constraints, indexes, and columns -->
            <dropIndex tableName="storage_position" indexName="idx_position_parent_device"/>
            <sql>
                ALTER TABLE storage_position DROP CONSTRAINT IF EXISTS chk_position_coordinate_requires_rack;
                ALTER TABLE storage_position DROP CONSTRAINT IF EXISTS chk_position_rack_requires_shelf;
            </sql>
            <dropColumn tableName="storage_position" columnName="parent_shelf_id"/>
            <dropColumn tableName="storage_position" columnName="parent_device_id"/>
            <!-- Restore NOT NULL constraints (this may fail if data exists) -->
            <sql>
                ALTER TABLE storage_position ALTER COLUMN parent_rack_id SET NOT NULL;
                ALTER TABLE storage_position ALTER COLUMN coordinate SET NOT NULL;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>

