<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Sample Storage Assignment Table -->
    <changeSet id="storage-011-create-sample-storage-assignment-table" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sample_storage_assignment"/>
            </not>
        </preConditions>
        <createTable tableName="sample_storage_assignment">
                <column name="id" type="numeric(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sample_id" type="numeric(10,0)">
                <constraints nullable="false" unique="true"
                    foreignKeyName="fk_assignment_sample"
                    references="sample(id)"
                    deleteCascade="true"/>
            </column>
                <column name="storage_position_id" type="numeric(10,0)">
                <constraints nullable="false"
                    foreignKeyName="fk_assignment_position"
                    references="storage_position(id)"
                    deleteCascade="false"/>
            </column>
                <column name="assigned_by_user_id" type="numeric(10,0)">
                <constraints nullable="false"
                    foreignKeyName="fk_assignment_user"
                    references="system_user(id)"/>
            </column>
            <column name="assigned_date" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
        </createTable>
        <rollback>
            <dropTable tableName="sample_storage_assignment"/>
        </rollback>
    </changeSet>

    <!-- Sample Storage Assignment Sequence -->
    <changeSet id="storage-012-create-sample-storage-assignment-sequence" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="sample_storage_assignment_seq"/>
            </not>
        </preConditions>
        <createSequence sequenceName="sample_storage_assignment_seq" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="sample_storage_assignment_seq"/>
        </rollback>
    </changeSet>

    <!-- Sample Storage Movement Table (Audit Log) -->
    <changeSet id="storage-013-create-sample-storage-movement-table" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sample_storage_movement"/>
            </not>
        </preConditions>
        <createTable tableName="sample_storage_movement">
                <column name="id" type="numeric(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sample_id" type="numeric(10,0)">
                <constraints nullable="false"
                    foreignKeyName="fk_movement_sample"
                    references="sample(id)"
                    deleteCascade="true"/>
            </column>
                <column name="previous_position_id" type="numeric(10,0)">
                <constraints foreignKeyName="fk_movement_previous_position"
                    references="storage_position(id)"
                    deleteCascade="false"/>
            </column>
                <column name="new_position_id" type="numeric(10,0)">
                <constraints foreignKeyName="fk_movement_new_position"
                    references="storage_position(id)"
                    deleteCascade="false"/>
            </column>
                <column name="moved_by_user_id" type="numeric(10,0)">
                <constraints nullable="false"
                    foreignKeyName="fk_movement_user"
                    references="system_user(id)"/>
            </column>
            <column name="movement_date" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="TEXT"/>
        </createTable>
        <rollback>
            <dropTable tableName="sample_storage_movement"/>
        </rollback>
    </changeSet>

    <!-- Sample Storage Movement Constraints -->
    <changeSet id="storage-013a-add-movement-constraints" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <not>
                <sqlCheck expectedResult="1">SELECT COUNT(*) FROM information_schema.table_constraints WHERE constraint_name = 'chk_movement_has_position' AND table_name = 'sample_storage_movement'</sqlCheck>
            </not>
        </preConditions>
        <sql>
            ALTER TABLE clinlims.sample_storage_movement
            ADD CONSTRAINT chk_movement_has_position
            CHECK (previous_position_id IS NOT NULL OR new_position_id IS NOT NULL);
        </sql>
    </changeSet>

    <!-- Sample Storage Movement Sequence -->
    <changeSet id="storage-014-create-sample-storage-movement-sequence" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="sample_storage_movement_seq"/>
            </not>
        </preConditions>
        <createSequence sequenceName="sample_storage_movement_seq" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="sample_storage_movement_seq"/>
        </rollback>
    </changeSet>

    <!-- Add last_updated column to sample_storage_assignment (required by BaseObject) -->
    <changeSet id="storage-015-add-last-updated-to-assignment" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_storage_assignment"/>
            <not>
                <columnExists tableName="sample_storage_assignment" columnName="last_updated"/>
            </not>
        </preConditions>
        <addColumn tableName="sample_storage_assignment">
            <column name="last_updated" type="TIMESTAMP"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="sample_storage_assignment" columnName="last_updated"/>
        </rollback>
    </changeSet>

    <!-- Add last_updated column to sample_storage_movement (required by BaseObject) -->
    <changeSet id="storage-016-add-last-updated-to-movement" author="sample-storage-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_storage_movement"/>
            <not>
                <columnExists tableName="sample_storage_movement" columnName="last_updated"/>
            </not>
        </preConditions>
        <addColumn tableName="sample_storage_movement">
            <column name="last_updated" type="TIMESTAMP"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="sample_storage_movement" columnName="last_updated"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
