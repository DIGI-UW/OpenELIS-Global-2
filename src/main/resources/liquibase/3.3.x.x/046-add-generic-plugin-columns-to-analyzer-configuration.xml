<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
        Generic Plugin Support for Analyzer Dashboard
        Feature: 004-analyzer-management + 011-madagascar-analyzer-integration

        Adds columns to support dashboard-configured analyzers via generic plugins:
        - identifier_pattern: Regex pattern to match analyzer from ASTM H-segment
        - is_generic_plugin: Flag to indicate analyzer is managed by generic plugin
    -->
    <changeSet id="046-add-generic-plugin-columns" author="generic-analyzer-plugin-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="analyzer_configuration"/>
            <not>
                <columnExists tableName="analyzer_configuration" columnName="identifier_pattern"/>
            </not>
        </preConditions>
        <comment>Add identifier_pattern and is_generic_plugin columns for generic plugin support</comment>

        <!-- Add identifier_pattern column for regex matching of ASTM H-segment -->
        <addColumn tableName="analyzer_configuration">
            <column name="identifier_pattern" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Add is_generic_plugin flag -->
        <addColumn tableName="analyzer_configuration">
            <column name="is_generic_plugin" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Create index for faster pattern lookups (generic plugins query by this) -->
        <createIndex indexName="idx_analyzer_config_generic_plugin" tableName="analyzer_configuration">
            <column name="is_generic_plugin"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_analyzer_config_generic_plugin" tableName="analyzer_configuration"/>
            <dropColumn tableName="analyzer_configuration" columnName="is_generic_plugin"/>
            <dropColumn tableName="analyzer_configuration" columnName="identifier_pattern"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
