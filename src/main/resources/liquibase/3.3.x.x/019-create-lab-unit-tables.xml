    <changeSet id="lab-unit-003-insert-initial-data" author="ogc-189-feature">
        <comment>Insert initial root lab unit</comment>
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM lab_unit</sqlCheck>
        </preConditions>
        <insert tableName="lab_unit">
            <column name="id" value="ROOT-LAB-UNIT"/>
            <column name="name" value="Main Laboratory"/>
            <column name="code" value="MAIN"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="sys_user_id" value="1"/>
        </insert>

        <rollback>
            <delete tableName="lab_unit">
                <where>id = 'ROOT-LAB-UNIT'</where>
            </delete>
        </rollback>
    </changeSet>

