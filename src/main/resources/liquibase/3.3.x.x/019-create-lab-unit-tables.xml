    <changeSet id="lab-unit-015-create-audit-functions" author="ogc-189-feature">
        <comment>Create audit functions for automatic change logging</comment>
        
        <sql dbms="postgresql">
            CREATE OR REPLACE FUNCTION log_lab_unit_changes()
            RETURNS TRIGGER AS $$
            BEGIN
                IF TG_OP = 'DELETE' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        OLD.id, 'DELETE', row_to_json(OLD), NULL, OLD.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN OLD;
                ELSIF TG_OP = 'UPDATE' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        NEW.id, 'UPDATE', row_to_json(OLD), row_to_json(NEW), NEW.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN NEW;
                ELSIF TG_OP = 'INSERT' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        NEW.id, 'INSERT', NULL, row_to_json(NEW), NEW.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN NEW;
                END IF;
                RETURN NULL;
            END;
            $$ LANGUAGE plpgsql;

            CREATE OR REPLACE FUNCTION log_assignment_changes()
            RETURNS TRIGGER AS $$
            BEGIN
                IF TG_OP = 'DELETE' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        OLD.lab_unit_id, 'DELETE', 
                        json_build_object(
                            'id', OLD.id,
                            'lab_unit_id', OLD.lab_unit_id,
                            'assignment_type', OLD.assignment_type,
                            'assigned_item_id', OLD.assigned_item_id,
                            'assigned_date', OLD.assigned_date,
                            'sys_user_id', OLD.sys_user_id
                        ), NULL, OLD.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN OLD;
                ELSIF TG_OP = 'UPDATE' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        NEW.lab_unit_id, 'UPDATE',
                        json_build_object(
                            'id', OLD.id,
                            'lab_unit_id', OLD.lab_unit_id,
                            'assignment_type', OLD.assignment_type,
                            'assigned_item_id', OLD.assigned_item_id,
                            'assigned_date', OLD.assigned_date,
                            'sys_user_id', OLD.sys_user_id
                        ),
                        json_build_object(
                            'id', NEW.id,
                            'lab_unit_id', NEW.lab_unit_id,
                            'assignment_type', NEW.assignment_type,
                            'assigned_item_id', NEW.assigned_item_id,
                            'assigned_date', NEW.assigned_date,
                            'sys_user_id', NEW.sys_user_id
                        ), NEW.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN NEW;
                ELSIF TG_OP = 'INSERT' THEN
                    INSERT INTO lab_unit_audit (
                        lab_unit_id, operation, old_values, new_values, changed_by, changed_at
                    ) VALUES (
                        NEW.lab_unit_id, 'INSERT', NULL,
                        json_build_object(
                            'id', NEW.id,
                            'lab_unit_id', NEW.lab_unit_id,
                            'assignment_type', NEW.assignment_type,
                            'assigned_item_id', NEW.assigned_item_id,
                            'assigned_date', NEW.assigned_date,
                            'sys_user_id', NEW.sys_user_id
                        ), NEW.sys_user_id, CURRENT_TIMESTAMP
                    );
                    RETURN NEW;
                END IF;
                RETURN NULL;
            END;
            $$ LANGUAGE plpgsql;
        </sql>

        <rollback>
            <sql dbms="postgresql">
                DROP FUNCTION IF EXISTS log_lab_unit_changes();
                DROP FUNCTION IF EXISTS log_assignment_changes();
            </sql>
        </rollback>
    </changeSet>

