        </createIndex>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_is_active">
            <column name="is_active"/>
        </createIndex>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_organization_id">
            <column name="organization_id"/>
        </createIndex>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_parent_id">
            <column name="parent_lab_unit_id"/>
        </createIndex>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_fhir_uuid">
            <column name="fhir_uuid"/>
        </createIndex>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_active_name">
            <column name="is_active"/>
            <column name="name"/>
        </createIndex>
        <rollback>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_code"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_name"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_display_order"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_is_active"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_organization_id"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_parent_id"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_fhir_uuid"/>
            <dropIndex tableName="lab_unit" indexName="idx_lab_unit_active_name"/>
