    <changeSet id="lab-unit-001-create-lab-unit-table" author="ogc-189-feature">
        <comment>Create lab_unit table for managing laboratory sections/departments</comment>
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="lab_unit"/>
            </not>
        </preConditions>
        <createTable tableName="lab_unit">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fhir_uuid" type="UUID">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="organization_id" type="VARCHAR(36)"/>
            <column name="parent_lab_unit_id" type="VARCHAR(36)"/>
            <column name="display_order" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="external_id" type="VARCHAR(50)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="sys_user_id" type="VARCHAR(36)"/>
            <column name="lastupdated" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="lab_unit"
            baseColumnNames="organization_id"
            referencedTableName="organization"
            referencedColumnNames="id"
            constraintName="fk_lab_unit_organization_id"
            onDelete="SET NULL"/>

        <addForeignKeyConstraint
            baseTableName="lab_unit"
            baseColumnNames="parent_lab_unit_id"
            referencedTableName="lab_unit"
            referencedColumnNames="id"
            constraintName="fk_lab_unit_parent_id"
            onDelete="SET NULL"/>

        <addCheckConstraint 
            tableName="lab_unit" 
            constraintName="chk_lab_unit_display_order_positive" 
            condition="display_order >= 0"/>

        <rollback>
            <dropTable tableName="lab_unit"/>
        </rollback>
    </changeSet>

    <changeSet id="lab-unit-002-add-lab-unit-indexes" author="ogc-189-feature">
        <comment>Add indexes for lab_unit table performance</comment>
        <createIndex tableName="lab_unit" indexName="idx_lab_unit_code" unique="true">
            <column name="code"/>
