<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Rename lastupdated column to last_updated to match BaseObject mapping -->
    <changeSet id="002-rename-lastupdated-to-last-updated" author="openelis">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="site_branding"/>
            <columnExists tableName="site_branding" columnName="lastupdated"/>
        </preConditions>
        <comment>Renaming lastupdated column to last_updated to match BaseObject column mapping</comment>
        <renameColumn
            tableName="site_branding"
            oldColumnName="lastupdated"
            newColumnName="last_updated"
            columnDataType="TIMESTAMP"/>

        <rollback>
            <renameColumn
                tableName="site_branding"
                oldColumnName="last_updated"
                newColumnName="lastupdated"
                columnDataType="TIMESTAMP"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
