<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Extend color column lengths to support CSS color formats beyond hex codes.
         This allows named colors (e.g., "rebeccapurple"), rgb(), hsl(), etc. -->
    <changeSet id="003-extend-color-column-length" author="openelis">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="site_branding"/>
        </preConditions>
        <comment>Extend color columns from VARCHAR(7) to VARCHAR(50) to support all CSS color formats</comment>

        <modifyDataType tableName="site_branding" columnName="primary_color" newDataType="VARCHAR(50)"/>
        <modifyDataType tableName="site_branding" columnName="secondary_color" newDataType="VARCHAR(50)"/>
        <modifyDataType tableName="site_branding" columnName="accent_color" newDataType="VARCHAR(50)"/>

        <rollback>
            <modifyDataType tableName="site_branding" columnName="primary_color" newDataType="VARCHAR(7)"/>
            <modifyDataType tableName="site_branding" columnName="secondary_color" newDataType="VARCHAR(7)"/>
            <modifyDataType tableName="site_branding" columnName="accent_color" newDataType="VARCHAR(7)"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
