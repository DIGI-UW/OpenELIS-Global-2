<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- QC Corrective Action Table -->
    <changeSet id="qc-008-create-qc-corrective-action" author="openelisglobal">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="qc_corrective_action"/>
            </not>
        </preConditions>
        <comment>Create QC corrective action table for managing violation resolution workflows</comment>
        <createTable tableName="qc_corrective_action">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="violation_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="action_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_user_id" type="INT"/>
            <column name="created_by_user_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_date_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="started_date_time" type="TIMESTAMP"/>
            <column name="completed_date_time" type="TIMESTAMP"/>
            <column name="resolution_notes" type="TEXT"/>
            <column name="sys_user_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="qc_corrective_action"
            baseColumnNames="violation_id"
            constraintName="fk_qc_action_violation"
            referencedTableName="qc_rule_violation"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="qc_corrective_action"
            baseColumnNames="assigned_user_id"
            constraintName="fk_qc_action_assigned_user"
            referencedTableName="system_user"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="qc_corrective_action"
            baseColumnNames="created_by_user_id"
            constraintName="fk_qc_action_created_user"
            referencedTableName="system_user"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="qc_corrective_action"
            baseColumnNames="sys_user_id"
            constraintName="fk_qc_action_sys_user"
            referencedTableName="system_user"
            referencedColumnNames="id"/>
        <createIndex tableName="qc_corrective_action" indexName="idx_qc_action_violation">
            <column name="violation_id"/>
        </createIndex>
        <createIndex tableName="qc_corrective_action" indexName="idx_qc_action_assigned">
            <column name="assigned_user_id"/>
        </createIndex>
        <createIndex tableName="qc_corrective_action" indexName="idx_qc_action_status">
            <column name="status"/>
        </createIndex>
        <rollback>
            <dropTable tableName="qc_corrective_action"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
