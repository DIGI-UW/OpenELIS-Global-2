<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- QC evaluation fields on Result entity (OGC-554 FR-02) -->
    <changeSet id="qc-012-add-result-qc-evaluation" author="openelisglobal">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="result" columnName="qc_evaluation"/>
            </not>
        </preConditions>
        <comment>Add QC evaluation columns to result table (OGC-554)</comment>
        <addColumn tableName="result">
            <column name="qc_evaluation" type="VARCHAR(10)"/>
            <column name="qc_evaluation_detail" type="VARCHAR(500)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="result" columnName="qc_evaluation"/>
            <dropColumn tableName="result" columnName="qc_evaluation_detail"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
