<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="010-add-skip-rows-to-file-import-config" author="pmanko">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="file_import_configuration"/>
            <not>
                <columnExists tableName="file_import_configuration" columnName="skip_rows"/>
            </not>
        </preConditions>
        <comment>Add skip_rows column for instruments with metadata lines before headers (e.g. Wondfo Finecare)</comment>
        <addColumn tableName="file_import_configuration">
            <column name="skip_rows" type="INTEGER" defaultValueNumeric="0"/>
        </addColumn>
        <update tableName="file_import_configuration">
            <column name="skip_rows" valueNumeric="0"/>
            <where>skip_rows IS NULL</where>
        </update>
        <addNotNullConstraint tableName="file_import_configuration"
                              columnName="skip_rows"
                              columnDataType="INTEGER"/>
        <rollback>
            <dropColumn tableName="file_import_configuration" columnName="skip_rows"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
