<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="010-add-skip-rows-to-file-import-config" author="pmanko">
        <comment>Add skip_rows column for instruments with metadata lines before headers (e.g. Wondfo Finecare)</comment>
        <addColumn tableName="file_import_configuration">
            <column name="skip_rows" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
