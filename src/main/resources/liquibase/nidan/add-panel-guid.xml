<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="add-panel-guid-column" author="Pravin Timalsina">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="clinlims" tableName="panel" columnName="guid"/>
            </not>
        </preConditions>

        <addColumn schemaName="clinlims" tableName="panel">
            <column name="guid" type="VARCHAR(128)"/>
        </addColumn>

        <!-- Optional but useful: ensure panel GUIDs are unique when present -->
        <sql>
            CREATE UNIQUE INDEX IF NOT EXISTS panel_guid_uk
            ON clinlims.panel (guid)
            WHERE guid IS NOT NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
