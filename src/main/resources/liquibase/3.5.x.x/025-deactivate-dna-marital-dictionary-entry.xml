<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!--
    LO-01-01 (UAT Round 2): the marital status dropdown showed a stray "DNA"
    option from a legacy 2012-06-11 seed row in dictionary id=1089
    (display_key=dictionary.marriage.DNA). "DNA" has no recognized meaning as
    a marital state; soft-deactivate so it no longer surfaces in the
    PATIENT_MARITAL_STATUS display list.

    Soft deactivation (is_active='N') is preferred over DELETE so the row
    remains referentially intact in case any historical patient_identity
    row was created against it.
  -->
  <changeSet author="oe" id="025-deactivate-dna-marital-dictionary-entry-1">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="1">
        SELECT COUNT(*) FROM clinlims.dictionary
         WHERE id = 1089 AND dict_entry = 'DNA' AND is_active = 'Y'
      </sqlCheck>
    </preConditions>
    <update schemaName="clinlims" tableName="dictionary">
      <column name="is_active" value="N"/>
      <column name="lastupdated" valueDate="now()"/>
      <where>id = 1089 AND dict_entry = 'DNA'</where>
    </update>
    <rollback>
      <update schemaName="clinlims" tableName="dictionary">
        <column name="is_active" value="Y"/>
        <where>id = 1089 AND dict_entry = 'DNA'</where>
      </update>
    </rollback>
  </changeSet>

</databaseChangeLog>
