            <not>
                <columnExists tableName="biorepository_qc_inspection" schemaName="clinlims"
                    columnName="correction_old_coordinate"/>
            </not>
        </preConditions>
        <addColumn tableName="biorepository_qc_inspection" schemaName="clinlims">
            <column name="correction_old_coordinate" type="TEXT"/>
        </addColumn>
    </changeSet>

