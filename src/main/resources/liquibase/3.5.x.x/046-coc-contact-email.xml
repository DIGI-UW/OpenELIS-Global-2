<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!--
    Adds coc_contact_email to referral_subcontract so the COC_CONTACT
    recipient can resolve to an email address (the EMAIL channel was
    previously skipped for this recipient because no email column existed).
  -->

  <changeSet id="3.5.0.0-add-coc-contact-email" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="referral_subcontract" columnName="coc_contact_email" schemaName="clinlims"/>
      </not>
    </preConditions>
    <addColumn tableName="referral_subcontract" schemaName="clinlims">
      <column name="coc_contact_email" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
    </addColumn>
  </changeSet>

</databaseChangeLog>
