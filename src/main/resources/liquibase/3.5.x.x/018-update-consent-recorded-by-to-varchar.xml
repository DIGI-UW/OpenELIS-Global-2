<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Update consent_recorded_by field to store names instead of user IDs -->
    <changeSet id="OGC-558-2026-04-30-1" author="herbertYiga">
        <preConditions onFail="MARK_RAN">
            <columnExists schemaName="clinlims" tableName="sample" columnName="consent_recorded_by"/>
        </preConditions>

        <!-- Drop foreign key constraint first -->
        <dropForeignKeyConstraint schemaName="clinlims" baseTableName="sample" constraintName="fk_sample_consent_recorded_by"/>

        <!-- Change column type from NUMERIC to VARCHAR -->
        <modifyDataType schemaName="clinlims" tableName="sample" columnName="consent_recorded_by" newDataType="VARCHAR(255)"/>

        <!-- Rollback -->
        <rollback>
            <!-- Change back to NUMERIC -->
            <modifyDataType schemaName="clinlims" tableName="sample" columnName="consent_recorded_by" newDataType="NUMERIC(10)"/>

            <!-- Re-add foreign key constraint -->
            <addForeignKeyConstraint schemaName="clinlims"
                                     baseTableName="sample"
                                     baseColumnNames="consent_recorded_by"
                                     constraintName="fk_sample_consent_recorded_by"
                                     referencedTableName="system_user"
                                     referencedColumnNames="id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
