<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="inventory-add-missing-enzyme-type-column" author="ahri-inventory">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="clinlims" tableName="inventory_item" columnName="enzyme_type"/>
            </not>
        </preConditions>
        <comment>Add missing enzyme_type column expected by InventoryItem mapping.</comment>
        <addColumn schemaName="clinlims" tableName="inventory_item">
            <column name="enzyme_type" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
