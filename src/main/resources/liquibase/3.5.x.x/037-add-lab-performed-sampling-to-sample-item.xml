<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add lab_performed_sampling boolean to sample_item -->
    <changeSet id="OGC-625-2026-06-02-1" author="reagan-meant">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="clinlims" tableName="sample_item" columnName="lab_performed_sampling"/>
            </not>
        </preConditions>
        <addColumn schemaName="clinlims" tableName="sample_item">
            <column name="lab_performed_sampling" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
