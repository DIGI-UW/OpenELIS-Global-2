<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!--
    OGC-624 / S-14 — second event for the configurable Notification Trigger
    system: SUBCONTRACT_DISPATCHED. Fires when a subcontract transitions to
    DISPATCHED via ReferralServiceImpl.transition(). Seeded disabled; admin
    activates and selects channels/recipients via the existing admin screen.

    Adds a new payload template (subject + message body using subcontract
    variables [agreementReference], [handoffDatetime], [expectedReturnDate],
    [cocContactName] alongside the shared [sampleAccessionNumber], [labName],
    [referralId] variables).
  -->

  <changeSet id="3.5.0.0-seed-subcontract-dispatched-template" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.notification_payload_template
        WHERE type = 'SUBCONTRACT_DISPATCHED'
      </sqlCheck>
    </preConditions>
    <insert tableName="notification_payload_template" schemaName="clinlims">
      <column name="id" valueComputed="nextval('clinlims.notification_payload_template_seq')"/>
      <column name="type" value="SUBCONTRACT_DISPATCHED"/>
      <column name="subject_template" value="Sample dispatched: [agreementReference]"/>
      <column name="message_template" value="Sample [sampleAccessionNumber] (referral [referralId]) has been dispatched to [labName]. Handoff at [handoffDatetime]. Expected return: [expectedReturnDate]. CoC contact: [cocContactName]."/>
      <column name="last_updated" valueComputed="now()"/>
    </insert>
  </changeSet>

  <changeSet id="3.5.0.0-seed-subcontract-dispatched-trigger" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.notification_trigger_config
        WHERE event_code = 'SUBCONTRACT_DISPATCHED'
      </sqlCheck>
    </preConditions>
    <insert tableName="notification_trigger_config" schemaName="clinlims">
      <column name="id" valueComputed="nextval('clinlims.notification_trigger_config_seq')"/>
      <column name="event_code" value="SUBCONTRACT_DISPATCHED"/>
      <column name="enabled" valueBoolean="false"/>
      <column name="payload_template_id"
              valueComputed="(SELECT id FROM clinlims.notification_payload_template
                              WHERE type = 'SUBCONTRACT_DISPATCHED')"/>
      <column name="last_updated" valueComputed="now()"/>
    </insert>
  </changeSet>

</databaseChangeLog>
