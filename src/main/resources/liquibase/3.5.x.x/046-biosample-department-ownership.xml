<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="046-biosample-department-ownership-column" author="ahri-rbac">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bio_sample" schemaName="clinlims"/>
            <not>
                <columnExists tableName="bio_sample" schemaName="clinlims" columnName="department_test_section_id"/>
            </not>
        </preConditions>
        <comment>Add durable owning department for biorepository sample registration.</comment>
        <addColumn tableName="bio_sample" schemaName="clinlims">
            <column name="department_test_section_id" type="INTEGER">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="046-biosample-department-ownership-index" author="ahri-rbac">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bio_sample" schemaName="clinlims"/>
            <columnExists tableName="bio_sample" schemaName="clinlims" columnName="department_test_section_id"/>
            <not>
                <indexExists indexName="idx_bio_sample_department_test_section_id" schemaName="clinlims"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_bio_sample_department_test_section_id" tableName="bio_sample" schemaName="clinlims">
            <column name="department_test_section_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
