<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!--
    S-14 / OGC-624 Inter-Lab Transfer & Subcontract — metadata persistence.

    Adds referral_subcontract table joined 1:1 to referral via referral.subcontract_id.
    Captures the FRS §4 metadata fields plus the FR-02 subcontract_status lifecycle.
    Always-create semantics: every new Refer Out gets a paired referral_subcontract row.
    Existing referral rows are left without a subcontract row (no backfill).

    Out of scope here (separate ticket): the 5-state status transition workflow,
    referral_status_history audit table, dashboard filter integration, FHIR ServiceRequest
    refactor, UI plumbing.
  -->

  <changeSet id="3.5.0.0-create-referral-subcontract-seq" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <sequenceExists sequenceName="referral_subcontract_seq" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createSequence sequenceName="referral_subcontract_seq" schemaName="clinlims"
                    startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="3.5.0.0-create-referral-subcontract-table" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="referral_subcontract" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createTable tableName="referral_subcontract" schemaName="clinlims">
      <column name="id" type="numeric(10,0)">
        <constraints primaryKey="true" nullable="false" primaryKeyName="referral_subcontract_pk"/>
      </column>
      <column name="subcontract_status" type="VARCHAR(30)" defaultValue="DRAFT">
        <constraints nullable="false"/>
      </column>
      <column name="agreement_reference" type="VARCHAR(100)">
        <constraints nullable="true"/>
      </column>
      <column name="handoff_datetime" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="true"/>
      </column>
      <column name="expected_return_date" type="DATE">
        <constraints nullable="true"/>
      </column>
      <column name="coc_contact_name" type="VARCHAR(100)">
        <constraints nullable="true"/>
      </column>
      <column name="coc_contact_phone" type="VARCHAR(50)">
        <constraints nullable="true"/>
      </column>
      <column name="subcontract_notes" type="VARCHAR(500)">
        <constraints nullable="true"/>
      </column>
      <column name="lastupdated" type="TIMESTAMP">
        <constraints nullable="true"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="3.5.0.0-referral-add-subcontract-id" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="referral" columnName="subcontract_id" schemaName="clinlims"/>
      </not>
    </preConditions>
    <addColumn tableName="referral" schemaName="clinlims">
      <column name="subcontract_id" type="numeric(10,0)">
        <constraints nullable="true"
                     foreignKeyName="fk_referral_subcontract"
                     referencedTableName="referral_subcontract"
                     referencedTableSchemaName="clinlims"
                     referencedColumnNames="id"/>
      </column>
    </addColumn>
  </changeSet>

  <changeSet id="3.5.0.0-referral-subcontract-status-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_referral_subcontract_status" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex tableName="referral_subcontract" schemaName="clinlims"
                 indexName="idx_referral_subcontract_status">
      <column name="subcontract_status"/>
    </createIndex>
  </changeSet>

  <changeSet id="3.5.0.0-referral-subcontract-expected-return-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_referral_subcontract_expected_return" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex tableName="referral_subcontract" schemaName="clinlims"
                 indexName="idx_referral_subcontract_expected_return">
      <column name="expected_return_date"/>
    </createIndex>
  </changeSet>

  <changeSet id="3.5.0.0-referral-subcontract-id-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_referral_subcontract_id" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex tableName="referral" schemaName="clinlims"
                 indexName="idx_referral_subcontract_id">
      <column name="subcontract_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
