<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- SAMPLE TRANSFER REQUEST TABLE -->
    <!-- Tracks internal lab sample transfers to the biorepository -->
    <!-- Supports bulk transfers with multiple samples per request -->
    <!-- ======================================================== -->

    <changeSet id="create-sample-transfer-request-sequence" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="sample_transfer_request_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sequence for sample_transfer_request table</comment>
        <createSequence sequenceName="sample_transfer_request_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="sample_transfer_request_seq" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="create-sample-transfer-request-table" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sample_transfer_request table for internal lab transfers to biorepository</comment>

        <createTable tableName="sample_transfer_request" schemaName="clinlims">
            <column name="id" type="NUMERIC(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_lab" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="destination_lab" type="VARCHAR(50)" defaultValue="BIOREPOSITORY">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="requested_by_user_id" type="NUMERIC(10,0)">
                <constraints nullable="false"/>
            </column>
            <column name="requested_timestamp" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="request_notes" type="TEXT"/>
            <column name="processed_by_user_id" type="NUMERIC(10,0)"/>
            <column name="processed_timestamp" type="TIMESTAMP"/>
            <column name="rejection_reason" type="TEXT"/>
            <column name="sys_user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="${now}"/>
        </createTable>

        <rollback>
            <dropTable tableName="sample_transfer_request" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-request-fk-requested-by" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            <tableExists tableName="system_user" schemaName="clinlims"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_request_requested_by" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add foreign key from sample_transfer_request.requested_by_user_id to system_user</comment>

        <addForeignKeyConstraint
            constraintName="fk_transfer_request_requested_by"
            baseTableSchemaName="clinlims"
            baseTableName="sample_transfer_request"
            baseColumnNames="requested_by_user_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            onDelete="RESTRICT"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableSchemaName="clinlims"
                baseTableName="sample_transfer_request"
                constraintName="fk_transfer_request_requested_by"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-request-fk-processed-by" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            <tableExists tableName="system_user" schemaName="clinlims"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_request_processed_by" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add foreign key from sample_transfer_request.processed_by_user_id to system_user</comment>

        <addForeignKeyConstraint
            constraintName="fk_transfer_request_processed_by"
            baseTableSchemaName="clinlims"
            baseTableName="sample_transfer_request"
            baseColumnNames="processed_by_user_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            onDelete="SET NULL"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableSchemaName="clinlims"
                baseTableName="sample_transfer_request"
                constraintName="fk_transfer_request_processed_by"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-request-indexes" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            <not>
                <indexExists indexName="idx_transfer_request_status" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add indexes for sample_transfer_request table</comment>

        <createIndex indexName="idx_transfer_request_status" tableName="sample_transfer_request" schemaName="clinlims">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_transfer_request_source_lab" tableName="sample_transfer_request" schemaName="clinlims">
            <column name="source_lab"/>
        </createIndex>

        <createIndex indexName="idx_transfer_request_requested_timestamp" tableName="sample_transfer_request" schemaName="clinlims">
            <column name="requested_timestamp"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_transfer_request_status" tableName="sample_transfer_request" schemaName="clinlims"/>
            <dropIndex indexName="idx_transfer_request_source_lab" tableName="sample_transfer_request" schemaName="clinlims"/>
            <dropIndex indexName="idx_transfer_request_requested_timestamp" tableName="sample_transfer_request" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-request-status-check" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
        </preConditions>
        <comment>Add check constraint for status values</comment>

        <sql>
            ALTER TABLE clinlims.sample_transfer_request
            ADD CONSTRAINT chk_transfer_request_status
            CHECK (status IN ('PENDING', 'ACCEPTED', 'PARTIALLY_ACCEPTED', 'REJECTED', 'CANCELLED'));
        </sql>

        <rollback>
            <sql>
                ALTER TABLE clinlims.sample_transfer_request DROP CONSTRAINT IF EXISTS chk_transfer_request_status;
            </sql>
        </rollback>
    </changeSet>

    <!-- ======================================================== -->
    <!-- SAMPLE TRANSFER ITEM TABLE -->
    <!-- Individual items within a transfer request -->
    <!-- Links to existing SampleItem records -->
    <!-- ======================================================== -->

    <changeSet id="create-sample-transfer-item-sequence" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="sample_transfer_item_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sequence for sample_transfer_item table</comment>
        <createSequence sequenceName="sample_transfer_item_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="sample_transfer_item_seq" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="create-sample-transfer-item-table" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sample_transfer_item table for individual samples in a transfer request</comment>

        <createTable tableName="sample_transfer_item" schemaName="clinlims">
            <column name="id" type="NUMERIC(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="transfer_request_id" type="NUMERIC(10,0)">
                <constraints nullable="false"/>
            </column>
            <column name="sample_item_id" type="NUMERIC(10,0)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="rejection_reason" type="TEXT"/>
            <column name="bio_sample_id" type="NUMERIC(10,0)"/>
            <column name="sys_user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="${now}"/>
        </createTable>

        <rollback>
            <dropTable tableName="sample_transfer_item" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-fk-request" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_item_request" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add foreign key from sample_transfer_item.transfer_request_id to sample_transfer_request</comment>

        <addForeignKeyConstraint
            constraintName="fk_transfer_item_request"
            baseTableSchemaName="clinlims"
            baseTableName="sample_transfer_item"
            baseColumnNames="transfer_request_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="sample_transfer_request"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableSchemaName="clinlims"
                baseTableName="sample_transfer_item"
                constraintName="fk_transfer_item_request"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-fk-sample-item" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <tableExists tableName="sample_item" schemaName="clinlims"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_item_sample_item" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add foreign key from sample_transfer_item.sample_item_id to sample_item</comment>

        <addForeignKeyConstraint
            constraintName="fk_transfer_item_sample_item"
            baseTableSchemaName="clinlims"
            baseTableName="sample_transfer_item"
            baseColumnNames="sample_item_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="sample_item"
            referencedColumnNames="id"
            onDelete="RESTRICT"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableSchemaName="clinlims"
                baseTableName="sample_transfer_item"
                constraintName="fk_transfer_item_sample_item"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-fk-bio-sample" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <tableExists tableName="bio_sample" schemaName="clinlims"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_item_bio_sample" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add foreign key from sample_transfer_item.bio_sample_id to bio_sample (created on acceptance)</comment>

        <addForeignKeyConstraint
            constraintName="fk_transfer_item_bio_sample"
            baseTableSchemaName="clinlims"
            baseTableName="sample_transfer_item"
            baseColumnNames="bio_sample_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="bio_sample"
            referencedColumnNames="id"
            onDelete="SET NULL"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableSchemaName="clinlims"
                baseTableName="sample_transfer_item"
                constraintName="fk_transfer_item_bio_sample"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-indexes" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <not>
                <indexExists indexName="idx_transfer_item_request" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add indexes for sample_transfer_item table</comment>

        <createIndex indexName="idx_transfer_item_request" tableName="sample_transfer_item" schemaName="clinlims">
            <column name="transfer_request_id"/>
        </createIndex>

        <createIndex indexName="idx_transfer_item_sample_item" tableName="sample_transfer_item" schemaName="clinlims">
            <column name="sample_item_id"/>
        </createIndex>

        <createIndex indexName="idx_transfer_item_status" tableName="sample_transfer_item" schemaName="clinlims">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_transfer_item_request" tableName="sample_transfer_item" schemaName="clinlims"/>
            <dropIndex indexName="idx_transfer_item_sample_item" tableName="sample_transfer_item" schemaName="clinlims"/>
            <dropIndex indexName="idx_transfer_item_status" tableName="sample_transfer_item" schemaName="clinlims"/>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-status-check" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
        </preConditions>
        <comment>Add check constraint for item status values</comment>

        <sql>
            ALTER TABLE clinlims.sample_transfer_item
            ADD CONSTRAINT chk_transfer_item_status
            CHECK (status IN ('PENDING', 'ACCEPTED', 'REJECTED'));
        </sql>

        <rollback>
            <sql>
                ALTER TABLE clinlims.sample_transfer_item DROP CONSTRAINT IF EXISTS chk_transfer_item_status;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="add-sample-transfer-item-unique-sample" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <not>
                <indexExists indexName="idx_transfer_item_unique_pending" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Add unique constraint to prevent duplicate pending transfers for same sample</comment>

        <!-- Partial unique index: only one pending transfer per sample_item -->
        <sql>
            CREATE UNIQUE INDEX idx_transfer_item_unique_pending
            ON clinlims.sample_transfer_item (sample_item_id)
            WHERE status = 'PENDING';
        </sql>

        <rollback>
            <sql>
                DROP INDEX IF EXISTS clinlims.idx_transfer_item_unique_pending;
            </sql>
        </rollback>
    </changeSet>

    <!-- ======================================================== -->
    <!-- FIX: Rename lastupdated to last_updated to match BaseObject -->
    <!-- BaseObject maps lastUpdated field to 'last_updated' column -->
    <!-- ======================================================== -->

    <changeSet id="fix-transfer-request-lastupdated-column" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_request" schemaName="clinlims"/>
            <columnExists tableName="sample_transfer_request" columnName="lastupdated" schemaName="clinlims"/>
        </preConditions>
        <comment>Rename lastupdated to last_updated to match BaseObject mapping</comment>

        <renameColumn tableName="sample_transfer_request"
                      schemaName="clinlims"
                      oldColumnName="lastupdated"
                      newColumnName="last_updated"
                      columnDataType="TIMESTAMP"/>

        <rollback>
            <renameColumn tableName="sample_transfer_request"
                          schemaName="clinlims"
                          oldColumnName="last_updated"
                          newColumnName="lastupdated"
                          columnDataType="TIMESTAMP"/>
        </rollback>
    </changeSet>

    <changeSet id="fix-transfer-item-lastupdated-column" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="sample_transfer_item" schemaName="clinlims"/>
            <columnExists tableName="sample_transfer_item" columnName="lastupdated" schemaName="clinlims"/>
        </preConditions>
        <comment>Rename lastupdated to last_updated to match BaseObject mapping</comment>

        <renameColumn tableName="sample_transfer_item"
                      schemaName="clinlims"
                      oldColumnName="lastupdated"
                      newColumnName="last_updated"
                      columnDataType="TIMESTAMP"/>

        <rollback>
            <renameColumn tableName="sample_transfer_item"
                          schemaName="clinlims"
                          oldColumnName="last_updated"
                          newColumnName="lastupdated"
                          columnDataType="TIMESTAMP"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
