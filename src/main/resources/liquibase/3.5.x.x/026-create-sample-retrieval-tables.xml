    <changeSet id="add-custody-log-action-check" author="openelis-biorepository">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="chain_of_custody_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Add check constraint for custody action values</comment>

        <sql>
            ALTER TABLE clinlims.chain_of_custody_log
            ADD CONSTRAINT chk_custody_log_action
            CHECK (custody_action IN (
                'CHECKOUT_REQUESTED', 'CHECKOUT_APPROVED', 'CHECKOUT_RETRIEVED', 'CHECKOUT_RELEASED',
                'TRANSFER_INITIATED', 'TRANSFER_IN_TRANSIT', 'TRANSFER_RECEIVED',
                'RETURN_INITIATED', 'RETURN_RECEIVED', 'RETURN_INSPECTED', 'RETURN_STORED'
            ));
        </sql>

        <rollback>
            <sql>
                ALTER TABLE clinlims.chain_of_custody_log DROP CONSTRAINT IF EXISTS chk_custody_log_action;
            </sql>
        </rollback>
    </changeSet>

