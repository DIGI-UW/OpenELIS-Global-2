<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="openelis" id="012-001-create-system-privilege">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="system_privilege" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create system_privilege table for atomic capability definitions (Phase 1 of privilege-based RBAC)</comment>
        <createTable tableName="system_privilege" schemaName="clinlims">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" primaryKeyName="system_privilege_pk"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="system_privilege_name_uq"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(50)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="sys_user_id" type="VARCHAR(255)"/>
        </createTable>
        <rollback>
            <dropTable tableName="system_privilege" schemaName="clinlims"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
