<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!-- OGC-775 (S-15a MVP): expanded measurement uncertainty fields on result -->
  <changeSet id="039-add-expanded-uncertainty-to-result" author="mherman22">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="result" columnName="expanded_uncertainty"/>
      </not>
    </preConditions>
    <addColumn tableName="result">
      <column name="expanded_uncertainty" type="DECIMAL(19,6)">
        <constraints nullable="true"/>
      </column>
      <column name="coverage_factor" type="DECIMAL(5,2)">
        <constraints nullable="true"/>
      </column>
    </addColumn>
    <rollback>
      <dropColumn tableName="result" columnName="expanded_uncertainty"/>
      <dropColumn tableName="result" columnName="coverage_factor"/>
    </rollback>
  </changeSet>

</databaseChangeLog>
