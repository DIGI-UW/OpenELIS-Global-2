<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="openelis" id="add-patient-gps-capture-config">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT count(*) FROM clinlims.site_information WHERE name = 'patientGpsCaptureEnabled'</sqlCheck>
        </preConditions>
        <comment>Admin toggle for patient registration GPS lat/long capture . Default off in core OE2; configurable under Admin &gt; General Configuration &gt; Patient Configuration Menu.</comment>
        <insert schemaName="clinlims" tableName="site_information">
            <column name="id" valueSequenceNext="site_information_seq" />
            <column name="name" value="patientGpsCaptureEnabled" />
            <column name="lastupdated" valueComputed="${now}" />
            <column name="description" value="Enable GPS latitude/longitude capture on patient registration" />
            <column name="value" value="false" />
            <column name="encrypted" value="false" />
            <column name="domain_id" valueComputed="(SELECT id FROM site_information_domain WHERE name = 'patientEntryConfig')" />
            <column name="value_type" value="boolean" />
            <column name="instruction_key" value="instructions.patient.gps.capture" />
            <column name="group" value="0" />
            <column name="description_key" value="siteInfo.patientGpsCaptureEnabled" />
        </insert>
    </changeSet>
</databaseChangeLog>
