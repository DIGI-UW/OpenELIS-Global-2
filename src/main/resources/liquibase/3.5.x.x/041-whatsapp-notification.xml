<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!-- Adds template_external_id (Twilio ContentSid handle) to notification_payload_template. -->

  <changeSet id="3.5.0.0-notification-payload-template-add-external-id" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="notification_payload_template" columnName="template_external_id" schemaName="clinlims"/>
      </not>
    </preConditions>
    <addColumn tableName="notification_payload_template" schemaName="clinlims">
      <column name="template_external_id" type="VARCHAR(100)">
        <constraints nullable="true"/>
      </column>
    </addColumn>
  </changeSet>

</databaseChangeLog>
