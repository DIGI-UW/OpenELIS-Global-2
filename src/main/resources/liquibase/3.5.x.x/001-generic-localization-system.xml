<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
        Generic Localization System

        This migration adds support for unlimited languages by normalizing translations
        into a separate table and removes the legacy 'english' and 'french' columns.

        Phases:
        1. Create supported_locale and localization_value tables
        2. Migrate existing english/french data to localization_value
        3. Add localization to dictionary entries
        4. Drop legacy columns
    -->

    <!-- ============================================================== -->
    <!-- Phase 1: Create Tables and Sequences                          -->
    <!-- ============================================================== -->

    <changeSet author="reagan-meant" id="3.5.0-001-create-supported-locale-seq">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="supported_locale_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <createSequence sequenceName="supported_locale_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-002-create-localization-value-seq">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="localization_value_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <createSequence sequenceName="localization_value_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-003-create-supported-locale-table">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="supported_locale" schemaName="clinlims"/>
            </not>
        </preConditions>
        <createTable tableName="supported_locale" schemaName="clinlims">
            <column name="id" type="numeric">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="locale_code" type="varchar(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="display_name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="is_fallback" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="timestamp with time zone"/>
        </createTable>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-004-create-localization-value-table">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="localization_value" schemaName="clinlims"/>
            </not>
        </preConditions>
        <createTable tableName="localization_value" schemaName="clinlims">
            <column name="id" type="numeric">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="localization_id" type="numeric">
                <constraints nullable="false"
                             foreignKeyName="fk_localization_value_localization"
                             references="clinlims.localization(id)"
                             deleteCascade="true"/>
            </column>
            <column name="locale" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="timestamp with time zone"/>
        </createTable>
        <addUniqueConstraint tableName="localization_value"
                             schemaName="clinlims"
                             columnNames="localization_id, locale"
                             constraintName="uq_localization_value_locale"/>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-005-create-localization-value-indexes">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="localization_value" schemaName="clinlims"/>
        </preConditions>
        <createIndex tableName="localization_value" schemaName="clinlims" indexName="idx_localization_value_locale">
            <column name="locale"/>
        </createIndex>
        <createIndex tableName="localization_value" schemaName="clinlims" indexName="idx_localization_value_localization_id">
            <column name="localization_id"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================== -->
    <!-- Phase 2: Seed Data and Migrate Existing Translations           -->
    <!-- ============================================================== -->

    <changeSet author="reagan-meant" id="3.5.0-006-seed-supported-locales">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="supported_locale" schemaName="clinlims"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM clinlims.supported_locale
                </sqlCheck>
            </and>
        </preConditions>
        <insert schemaName="clinlims" tableName="supported_locale">
            <column name="id" valueSequenceNext="supported_locale_seq"/>
            <column name="locale_code" value="en"/>
            <column name="display_name" value="English"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="is_fallback" valueBoolean="true"/>
            <column name="sort_order" valueNumeric="1"/>
            <column name="lastupdated" valueComputed="now()"/>
        </insert>
        <insert schemaName="clinlims" tableName="supported_locale">
            <column name="id" valueSequenceNext="supported_locale_seq"/>
            <column name="locale_code" value="fr"/>
            <column name="display_name" value="Francais"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="is_fallback" valueBoolean="false"/>
            <column name="sort_order" valueNumeric="2"/>
            <column name="lastupdated" valueComputed="now()"/>
        </insert>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-007-migrate-english-translations">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="localization_value" schemaName="clinlims"/>
                <columnExists tableName="localization" schemaName="clinlims" columnName="english"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM clinlims.localization_value WHERE locale = 'en'
                </sqlCheck>
            </and>
        </preConditions>
        <sql>
            INSERT INTO clinlims.localization_value (id, localization_id, locale, value, lastupdated)
            SELECT nextval('localization_value_seq'), id, 'en', english, COALESCE(lastupdated, now())
            FROM clinlims.localization
            WHERE english IS NOT NULL AND english != '';
        </sql>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-008-migrate-french-translations">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="localization_value" schemaName="clinlims"/>
                <columnExists tableName="localization" schemaName="clinlims" columnName="french"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM clinlims.localization_value WHERE locale = 'fr'
                </sqlCheck>
            </and>
        </preConditions>
        <sql>
            INSERT INTO clinlims.localization_value (id, localization_id, locale, value, lastupdated)
            SELECT nextval('localization_value_seq'), id, 'fr', french, COALESCE(lastupdated, now())
            FROM clinlims.localization
            WHERE french IS NOT NULL AND french != '';
        </sql>
    </changeSet>

    <!-- ============================================================== -->
    <!-- Phase 3: Add Localization to Dictionary Entries                -->
    <!-- ============================================================== -->

    <changeSet author="reagan-meant" id="3.5.0-009-add-dictionary-localization">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="dictionary" schemaName="clinlims"/>
                <tableExists tableName="localization" schemaName="clinlims"/>
                <tableExists tableName="localization_value" schemaName="clinlims"/>
                <sqlCheck expectedResult="0">
                    <!-- Only run if there are dictionaries without localization -->
                    SELECT CASE WHEN EXISTS (
                        SELECT 1 FROM clinlims.dictionary
                        WHERE name_localization_id IS NULL AND dict_entry IS NOT NULL
                    ) THEN 0 ELSE 1 END
                </sqlCheck>
            </and>
        </preConditions>
        <sql splitStatements="false">
            DO $$
            DECLARE
                dict_record RECORD;
                new_loc_id NUMERIC;
            BEGIN
                FOR dict_record IN
                    SELECT id, dict_entry
                    FROM clinlims.dictionary
                    WHERE name_localization_id IS NULL AND dict_entry IS NOT NULL
                LOOP
                    -- Create localization record (include legacy english/french columns for backward compatibility)
                    SELECT nextval('localization_seq') INTO new_loc_id;

                    INSERT INTO clinlims.localization (id, description, english, french, lastupdated)
                    VALUES (new_loc_id, 'dictionary name', dict_record.dict_entry, dict_record.dict_entry, now());

                    -- Create English translation only (other languages to be added via translation UI)
                    INSERT INTO clinlims.localization_value (id, localization_id, locale, value, lastupdated)
                    VALUES (nextval('localization_value_seq'), new_loc_id, 'en', dict_record.dict_entry, now());

                    -- Update dictionary with localization reference
                    UPDATE clinlims.dictionary
                    SET name_localization_id = new_loc_id
                    WHERE id = dict_record.id;
                END LOOP;
            END $$;
        </sql>
    </changeSet>

    <!-- ============================================================== -->
    <!-- Phase 4: Drop Legacy Columns                                   -->
    <!-- ============================================================== -->

    <changeSet author="reagan-meant" id="3.5.0-010-verify-data-migrated" runAlways="false">
        <preConditions onFail="HALT">
            <!-- Verify localization_value table exists and has data -->
            <tableExists tableName="localization_value" schemaName="clinlims"/>
            <sqlCheck expectedResult="0">
                <!-- Ensure no localizations are missing English translations in the new table -->
                SELECT COUNT(*)
                FROM clinlims.localization l
                WHERE l.english IS NOT NULL
                  AND l.english != ''
                  AND NOT EXISTS (
                    SELECT 1 FROM clinlims.localization_value lv
                    WHERE lv.localization_id = l.id AND lv.locale = 'en'
                  )
            </sqlCheck>
        </preConditions>
        <comment>Verify data has been migrated to localization_value table before dropping columns</comment>
        <sql>SELECT 1</sql>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-011-drop-english-column">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="localization" schemaName="clinlims" columnName="english"/>
        </preConditions>
        <dropColumn tableName="localization" schemaName="clinlims" columnName="english"/>
    </changeSet>

    <changeSet author="reagan-meant" id="3.5.0-012-drop-french-column">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="localization" schemaName="clinlims" columnName="french"/>
        </preConditions>
        <dropColumn tableName="localization" schemaName="clinlims" columnName="french"/>
    </changeSet>

</databaseChangeLog>
