<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <changeSet id="admin-menu-add-nav-scope-column" author="mherman22">
    <comment>
      Add nav_scope to clinlims.menu so admin items can live in the same
      table without bleeding into /rest/menu. Existing rows backfill to
      'lab' via DEFAULT; admin rows below set 'admin' explicitly.
    </comment>
    <addColumn tableName="menu" schemaName="clinlims">
      <column name="nav_scope" type="VARCHAR(16)" defaultValue="lab">
        <constraints nullable="false" />
      </column>
    </addColumn>
    <rollback>
      <dropColumn tableName="menu" schemaName="clinlims" columnName="nav_scope" />
    </rollback>
  </changeSet>

  <!--
    Admin sidenav rows seeded under nav_scope='admin'. Each row is its own
    changeSet (one row per change) following the convention in
    3.4.x.x/014-sample-collection-workflow-menus.xml: <sqlCheck> precondition
    + <insert> with valueComputed for parent_id lookups. Order in this file
    matches the original Admin.jsx sidenav order so reading top-to-bottom
    matches the rendered UX.
  -->

  <!-- Group parent: Reflex Tests Configurations -->
  <changeSet id="admin-menu-reflex-config-parent" author="mherman22">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT count(*) FROM clinlims.menu WHERE element_id = 'menu_admin_reflex_config'
      </sqlCheck>
    </preConditions>
    <insert tableName="menu" schemaName="clinlims">
      <column name="id" valueSequenceNext="menu_seq" />
      <column name="presentation_order" valueNumeric="10" />
      <column name="element_id" value="menu_admin_reflex_config" />
      <column name="action_url" value="" />
      <column name="display_key" value="sidenav.label.admin.testmgt" />
      <column name="nav_scope" value="admin" />
      <column name="is_active" valueBoolean="true" />
      <column name="hide_in_old_ui" valueBoolean="true" />
      <column name="new_window" valueBoolean="false" />
    </insert>
  </changeSet>

