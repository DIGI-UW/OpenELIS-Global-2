<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- TRANSPORT_PACKAGING TABLE -->
    <!-- Tracks IATA PI650 compliant packaging for sample transport -->
    <!-- Three-tier: primary, secondary, tertiary packaging -->
    <!-- ======================================================== -->
    <changeSet id="create-transport-packaging-sequence" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="transport_packaging_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating sequence for transport_packaging table.</comment>
        <createSequence sequenceName="transport_packaging_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="create-transport-packaging-table" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="transport_packaging" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating TRANSPORT_PACKAGING table for IATA PI650 compliance tracking.</comment>
        <createTable tableName="transport_packaging">
            <column name="id" type="INTEGER" defaultValueSequenceNext="transport_packaging_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_transport_packaging"/>
            </column>
            <column name="shipment_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <!-- Primary container (individual sample containers) -->
            <column name="primary_container_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="primary_seal_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="primary_barcode_present" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="primary_absorbent_present" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <!-- Secondary packaging (protective layer) -->
            <column name="secondary_packaging_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_integrity" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_watertight" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_container_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_inspector_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_inspection_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_receipt_condition" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <!-- Tertiary packaging (outer shipping container) -->
            <column name="tertiary_box_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tertiary_labeling_status" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="tertiary_temp_logger_id" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="tertiary_courier_company" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="tertiary_tracking_number" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="tertiary_arrival_condition" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <!-- Overall compliance -->
            <column name="iata_pi650_compliant" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="transportation_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="collection_temperature" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="received_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="fhir_uuid" type="UUID">
                <constraints nullable="true" unique="true" uniqueConstraintName="uq_tp_fhir_uuid"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="add-transport-packaging-foreign-keys" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding foreign key constraints to transport_packaging table.</comment>
        <addForeignKeyConstraint
            baseTableName="transport_packaging"
            baseColumnNames="secondary_inspector_id"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_tp_inspector"/>
    </changeSet>

    <changeSet id="add-transport-packaging-seal-status-check" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for primary_seal_status values.</comment>
        <sql>
            ALTER TABLE clinlims.transport_packaging
            ADD CONSTRAINT chk_tp_seal_status
            CHECK (primary_seal_status IN ('INTACT', 'LEAKING', 'DAMAGED'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.transport_packaging DROP CONSTRAINT IF EXISTS chk_tp_seal_status;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-transport-packaging-integrity-check" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for secondary_integrity values.</comment>
        <sql>
            ALTER TABLE clinlims.transport_packaging
            ADD CONSTRAINT chk_tp_integrity
            CHECK (secondary_integrity IN ('INTACT', 'TORN', 'WET', 'LEAKING'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.transport_packaging DROP CONSTRAINT IF EXISTS chk_tp_integrity;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-transport-packaging-receipt-check" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for secondary_receipt_condition values.</comment>
        <sql>
            ALTER TABLE clinlims.transport_packaging
            ADD CONSTRAINT chk_tp_receipt
            CHECK (secondary_receipt_condition IN ('ACCEPTABLE', 'REJECTED'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.transport_packaging DROP CONSTRAINT IF EXISTS chk_tp_receipt;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-transport-packaging-arrival-check" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for tertiary_arrival_condition values.</comment>
        <sql>
            ALTER TABLE clinlims.transport_packaging
            ADD CONSTRAINT chk_tp_arrival
            CHECK (tertiary_arrival_condition IN ('INTACT', 'DAMAGED'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.transport_packaging DROP CONSTRAINT IF EXISTS chk_tp_arrival;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-transport-packaging-transport-status-check" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for transportation_status values.</comment>
        <sql>
            ALTER TABLE clinlims.transport_packaging
            ADD CONSTRAINT chk_tp_transport_status
            CHECK (transportation_status IN ('ON_TIME', 'DELAYED'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.transport_packaging DROP CONSTRAINT IF EXISTS chk_tp_transport_status;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-transport-packaging-indexes" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="transport_packaging" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for query optimization.</comment>
        <createIndex tableName="transport_packaging" indexName="idx_tp_shipment">
            <column name="shipment_id"/>
        </createIndex>
        <createIndex tableName="transport_packaging" indexName="idx_tp_received">
            <column name="received_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-transport-packaging-reference-table" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.reference_tables WHERE name = 'TRANSPORT_PACKAGING'
            </sqlCheck>
        </preConditions>
        <comment>Creating TRANSPORT_PACKAGING reference table entry for audit trail tracking.</comment>
        <insert tableName="reference_tables" schemaName="clinlims">
            <column name="id" valueSequenceNext="reference_tables_seq"/>
            <column name="name" value="TRANSPORT_PACKAGING"/>
            <column name="keep_history" value="Y"/>
            <column name="is_hl7_encoded" value="N"/>
            <column name="lastupdated" valueComputed="${now}"/>
        </insert>
        <rollback>
            <delete schemaName="clinlims" tableName="reference_tables">
                <where>name='TRANSPORT_PACKAGING'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
