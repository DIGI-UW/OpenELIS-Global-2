<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- EQUIPMENT_USAGE_LOG TABLE -->
    <!-- Tracks laboratory equipment/instrument usage -->
    <!-- Supports accreditation requirements (ISO 15189, CAP, CLIA) -->
    <!-- ======================================================== -->
    <changeSet id="create-equipment-usage-log-sequence" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="equipment_usage_log_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating sequence for equipment_usage_log table.</comment>
        <createSequence sequenceName="equipment_usage_log_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="create-equipment-usage-log-table" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="equipment_usage_log" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating EQUIPMENT_USAGE_LOG table for instrument usage tracking.</comment>
        <createTable tableName="equipment_usage_log">
            <column name="id" type="INTEGER" defaultValueSequenceNext="equipment_usage_log_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_equipment_usage_log"/>
            </column>
            <column name="analyzer_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="usage_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="true"/>
            </column>
            <column name="operator_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="purpose" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="samples_processed" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="maintenance_done" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
            <column name="maintenance_notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="error_occurred" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="true"/>
            </column>
            <column name="error_description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="fhir_uuid" type="UUID">
                <constraints nullable="true" unique="true" uniqueConstraintName="uq_eul_fhir_uuid"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="add-equipment-usage-log-foreign-keys" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="equipment_usage_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding foreign key constraints to equipment_usage_log table.</comment>
        <addForeignKeyConstraint
            baseTableName="equipment_usage_log"
            baseColumnNames="analyzer_id"
            referencedTableName="analyzer"
            referencedColumnNames="id"
            constraintName="fk_eul_analyzer"/>
        <addForeignKeyConstraint
            baseTableName="equipment_usage_log"
            baseColumnNames="operator_id"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_eul_operator"/>
    </changeSet>

    <changeSet id="add-equipment-usage-log-indexes" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="equipment_usage_log" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for query optimization.</comment>
        <createIndex tableName="equipment_usage_log" indexName="idx_eul_analyzer_date">
            <column name="analyzer_id"/>
            <column name="usage_date"/>
        </createIndex>
        <createIndex tableName="equipment_usage_log" indexName="idx_eul_operator">
            <column name="operator_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-equipment-usage-log-reference-table" author="openelis-medlab">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.reference_tables WHERE name = 'EQUIPMENT_USAGE_LOG'
            </sqlCheck>
        </preConditions>
        <comment>Creating EQUIPMENT_USAGE_LOG reference table entry for audit trail tracking.</comment>
        <insert tableName="reference_tables" schemaName="clinlims">
            <column name="id" valueSequenceNext="reference_tables_seq"/>
            <column name="name" value="EQUIPMENT_USAGE_LOG"/>
            <column name="keep_history" value="Y"/>
            <column name="is_hl7_encoded" value="N"/>
            <column name="lastupdated" valueComputed="${now}"/>
        </insert>
        <rollback>
            <delete schemaName="clinlims" tableName="reference_tables">
                <where>name='EQUIPMENT_USAGE_LOG'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
