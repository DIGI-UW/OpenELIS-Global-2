<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add required_by to sample (order level) -->
    <changeSet id="OGC-625-2026-06-01-1" author="reagan-meant">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="clinlims" tableName="sample" columnName="required_by"/>
            </not>
        </preConditions>
        <addColumn schemaName="clinlims" tableName="sample">
            <column name="required_by" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
