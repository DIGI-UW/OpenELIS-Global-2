<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!--
    Notification delivery audit log — backs the admin Sent Messages tab.

    One `notification_log` row per (event, recipient, fire-instance). The
    dispatcher publishes a Spring ApplicationEvent after each fire; the
    NotificationLogService's @EventListener writes the row. Log-write failure
    is isolated from the dispatch path (try/catch in dispatcher).

    Per-channel outcomes live in `notification_log_channel` as an
    @ElementCollection of an @Embeddable — mirrors the precedent at
    notification_trigger_channel (migration 036). No optimistic-lock column
    on the child rows.

    Indexes target: (1) default ORDER BY fired_at DESC paging, (2) combined
    Type + Status filter from the admin UI, (3) future resend-chain queries.

    Privacy note: this table persists recipient email/phone + full rendered
    message bodies (which include patient identifiers via merge fields).
    ADMIN-gated at the REST layer; no retention TTL in this iteration.
  -->

  <changeSet id="3.5.0.0-create-notification-log-seq" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <sequenceExists sequenceName="notification_log_seq" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createSequence sequenceName="notification_log_seq" schemaName="clinlims"
                    startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="3.5.0.0-create-notification-log-table" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="notification_log" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createTable tableName="notification_log" schemaName="clinlims">
      <column name="id" type="BIGINT">
        <constraints primaryKey="true" nullable="false" primaryKeyName="notification_log_pk"/>
      </column>
      <column name="event_code" type="VARCHAR(64)">
        <constraints nullable="false"/>
      </column>
      <column name="fired_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
      <column name="triggered_by_user_id" type="VARCHAR(64)">
        <constraints nullable="true"/>
      </column>
      <column name="recipient_type" type="VARCHAR(32)">
        <constraints nullable="false"/>
      </column>
      <column name="recipient_display_name" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="recipient_email" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="recipient_phone" type="VARCHAR(64)">
        <constraints nullable="true"/>
      </column>
      <column name="reference_accession" type="VARCHAR(64)">
        <constraints nullable="true"/>
      </column>
      <column name="reference_workflow" type="VARCHAR(32)">
        <constraints nullable="true"/>
      </column>
      <column name="rendered_subject" type="VARCHAR(1000)">
        <constraints nullable="true"/>
      </column>
      <column name="rendered_message" type="VARCHAR(10000)">
        <constraints nullable="true"/>
      </column>
      <column name="overall_status" type="VARCHAR(16)">
        <constraints nullable="false"/>
      </column>
      <column name="resent_from_id" type="BIGINT">
        <constraints nullable="true"
                     foreignKeyName="fk_notification_log_resent_from"
                     referencedTableName="notification_log"
                     referencedTableSchemaName="clinlims"
                     referencedColumnNames="id"/>
      </column>
      <column name="last_updated" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="3.5.0.0-create-notification-log-channel-table" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="notification_log_channel" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createTable tableName="notification_log_channel" schemaName="clinlims">
      <column name="notification_log_id" type="BIGINT">
        <constraints nullable="false"
                     foreignKeyName="fk_notification_log_channel_parent"
                     referencedTableName="notification_log"
                     referencedTableSchemaName="clinlims"
                     referencedColumnNames="id"
                     deleteCascade="true"/>
      </column>
      <column name="channel" type="VARCHAR(16)">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="VARCHAR(16)">
        <constraints nullable="false"/>
      </column>
      <column name="error_message" type="VARCHAR(2000)">
        <constraints nullable="true"/>
      </column>
      <column name="attempts" type="INT" defaultValueNumeric="1">
        <constraints nullable="false"/>
      </column>
      <column name="last_attempted_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addPrimaryKey tableName="notification_log_channel" schemaName="clinlims"
                   columnNames="notification_log_id, channel"
                   constraintName="notification_log_channel_pk"/>
  </changeSet>

  <changeSet id="3.5.0.0-create-notification-log-fired-at-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_notification_log_fired_at" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex indexName="idx_notification_log_fired_at" tableName="notification_log" schemaName="clinlims">
      <column name="fired_at" descending="true"/>
    </createIndex>
  </changeSet>

  <changeSet id="3.5.0.0-create-notification-log-event-status-fired-at-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_notification_log_event_status_fired" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex indexName="idx_notification_log_event_status_fired" tableName="notification_log" schemaName="clinlims">
      <column name="event_code"/>
      <column name="overall_status"/>
      <column name="fired_at" descending="true"/>
    </createIndex>
  </changeSet>

  <changeSet id="3.5.0.0-create-notification-log-resent-from-index" author="samuelmale">
    <preConditions onFail="MARK_RAN">
      <not>
        <indexExists indexName="idx_notification_log_resent_from" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createIndex indexName="idx_notification_log_resent_from" tableName="notification_log" schemaName="clinlims">
      <column name="resent_from_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
