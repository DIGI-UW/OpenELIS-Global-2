<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
      OGC-650 (LO-01-01) — admin-surface the patient GPS capture toggle.

      Pairs with the OGC-650 work that introduced person.gps_latitude/gps_longitude
      columns and the CreatePatientForm.jsx render gate. Without this row, the
      property is configurable only via SystemConfiguration.properties (file-based
      override, distro-maintainer only). With this row, the toggle appears under
      Admin → Site Information (patientEntryConfig domain) and lab admins can flip
      it through the UI.

      Pattern follows liquibase/3.3.x.x/029-add-gps-coordinates-to-sample.xml
      (gpsCoordinatesEnabled seed by mherman22, OGC-300).
    -->
    <changeSet author="pmanko" id="OGC-650-2026-05-05-patient-gps-site-info">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">select count(*) from clinlims.site_information where name = 'patientGpsCaptureEnabled';</sqlCheck>
        </preConditions>
        <comment>OGC-650: surface patient GPS capture toggle in admin Site Information (patientEntryConfig domain)</comment>
        <insert schemaName="clinlims" tableName="site_information">
            <column name="id" valueSequenceNext="site_information_seq" />
            <column name="name" value="patientGpsCaptureEnabled" />
            <column name="lastupdated" valueComputed="${now}" />
            <column name="description" value="If true, GPS Latitude and Longitude fields render on the patient registration form." />
            <column name="value" value="false" />
            <column name="encrypted" value="false" />
            <column name="domain_id" valueComputed="(SELECT id FROM clinlims.site_information_domain WHERE name = 'patientEntryConfig')" />
            <column name="value_type" value="boolean" />
            <column name="instruction_key" value="instructions.patient.gps.capture" />
            <column name="group" value="0" />
        </insert>
    </changeSet>

</databaseChangeLog>
