<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================== -->
    <!-- Seed Notebook Experiment Types -->
    <!-- Adds dictionary entries for the notebook_experiment_type category -->
    <!-- ======================================================== -->

    <changeSet id="seed-notebook-experiment-types" author="claude">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.dictionary_category WHERE name = 'notebook_experiment_type'
            </sqlCheck>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.dictionary
                WHERE dictionary_category_id = (SELECT id FROM clinlims.dictionary_category WHERE name = 'notebook_experiment_type')
            </sqlCheck>
        </preConditions>
        <comment>Seeds notebook experiment type dictionary entries</comment>

        <!-- Immunology -->
        <insert tableName="dictionary" schemaName="clinlims">
            <column name="id" valueSequenceNext="dictionary_seq" />
            <column name="is_active" value="Y" />
            <column name="dict_entry" value="Immunology" />
            <column name="lastupdated" valueComputed="${now}" />
            <column name="local_abbrev" value="IMMUNO" />
            <column name="dictionary_category_id" valueComputed="(SELECT id FROM clinlims.dictionary_category WHERE name = 'notebook_experiment_type')" />
            <column name="sort_order" value="10" />
        </insert>

