<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add "Analyzers" parent menu item -->
    <changeSet author="astm-analyzer-mapping-feature" id="analyzer-009-add-menu-items-parent">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_analyzers'
            </sqlCheck>
        </preConditions>
        <comment>Adds Analyzers parent menu item</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column name="presentation_order" value="26" />
            <column name="element_id" value="menu_analyzers" />
            <column name="action_url" value="/analyzers" />
            <column name="display_key" value="analyzer.navigation.analyzers" />
            <column name="tool_tip_key" value="analyzer.navigation.analyzers" />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

    <!-- Add "Analyzers List" sub-menu item -->
    <changeSet author="astm-analyzer-mapping-feature" id="analyzer-009-add-menu-items-list">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_analyzers_list'
            </sqlCheck>
        </preConditions>
        <comment>Adds Analyzers List sub-menu item</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_analyzers')" />
            <column name="presentation_order" value="1" />
            <column name="element_id" value="menu_analyzers_list" />
            <column name="action_url" value="/analyzers" />
            <column name="display_key" value="analyzer.navigation.analyzersList" />
            <column name="tool_tip_key" value="analyzer.navigation.analyzersList" />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

    <!-- Add "Error Dashboard" sub-menu item -->
    <changeSet author="astm-analyzer-mapping-feature" id="analyzer-009-add-menu-items-errors">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_analyzers_errors'
            </sqlCheck>
        </preConditions>
        <comment>Adds Error Dashboard sub-menu item</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_analyzers')" />
            <column name="presentation_order" value="2" />
            <column name="element_id" value="menu_analyzers_errors" />
            <column name="action_url" value="/analyzers/errors" />
            <column name="display_key" value="analyzer.navigation.errorDashboard" />
            <column name="tool_tip_key" value="analyzer.navigation.errorDashboard" />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

    <!-- Add "Field Mappings" sub-menu item (contextual - visible when on /analyzers/:id/mappings route) -->
    <!-- Note: Contextual visibility is handled by frontend based on current route -->
    <!-- The menu item is always in the database but frontend filters based on route -->
    <changeSet author="astm-analyzer-mapping-feature" id="analyzer-009-add-menu-items-mappings">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_analyzers_field_mappings'
            </sqlCheck>
        </preConditions>
        <comment>Adds Field Mappings sub-menu item (contextual visibility handled by frontend)</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_analyzers')" />
            <column name="presentation_order" value="3" />
            <column name="element_id" value="menu_analyzers_field_mappings" />
            <column name="action_url" value="/analyzers/:id/mappings" />
            <column name="display_key" value="analyzer.navigation.fieldMappings" />
            <column name="tool_tip_key" value="analyzer.navigation.fieldMappings" />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

</databaseChangeLog>

