<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="analyzer-014-add-status-column-to-analyzer-configuration" author="astm-analyzer-mapping-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="analyzer_configuration"/>
            <not>
                <columnExists tableName="analyzer_configuration" columnName="status"/>
            </not>
        </preConditions>
        <comment>Add unified status field and last_activated_date column to analyzer_configuration table</comment>

        <!-- Add status column (unified field replacing lifecycle_stage and active boolean) -->
        <addColumn tableName="analyzer_configuration">
            <column name="status" type="VARCHAR(20)" defaultValue="SETUP">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Add last_activated_date column -->
        <addColumn tableName="analyzer_configuration">
            <column name="last_activated_date" type="TIMESTAMP"/>
        </addColumn>

        <!-- Add check constraint for unified status enum values -->
        <sql>
            ALTER TABLE analyzer_configuration
            ADD CONSTRAINT chk_analyzer_status
            CHECK (status IN ('INACTIVE', 'SETUP', 'VALIDATION', 'ACTIVE', 'ERROR_PENDING', 'OFFLINE', 'DELETED'));
        </sql>

        <!-- Create index for status filtering performance -->
        <createIndex indexName="idx_analyzer_configuration_status" tableName="analyzer_configuration">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_analyzer_configuration_status" tableName="analyzer_configuration"/>
            <sql>ALTER TABLE analyzer_configuration DROP CONSTRAINT IF EXISTS chk_analyzer_status;</sql>
            <dropColumn tableName="analyzer_configuration" columnName="last_activated_date"/>
            <dropColumn tableName="analyzer_configuration" columnName="status"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
