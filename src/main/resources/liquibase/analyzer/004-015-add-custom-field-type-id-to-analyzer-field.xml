<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="analyzer-015-add-custom-field-type-id-to-analyzer-field" author="astm-analyzer-mapping-feature">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="analyzer_field"/>
            <not>
                <columnExists tableName="analyzer_field" columnName="custom_field_type_id"/>
            </not>
        </preConditions>
        <comment>Adding custom_field_type_id column to analyzer_field table to support custom field types (T141)</comment>
        <addColumn tableName="analyzer_field">
            <column name="custom_field_type_id" type="VARCHAR(36)">
                <constraints nullable="true"
                    foreignKeyName="fk_analyzer_field_custom_field_type"
                    referencedTableName="custom_field_type"
                    referencedColumnNames="id"
                    deleteCascade="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="analyzer_field" columnName="custom_field_type_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
