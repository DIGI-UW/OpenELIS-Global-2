<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="3.4-020-add-has-setup-page" author="demo-madagascar-analyzer">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="analyzer" columnName="has_setup_page"/>
            </not>
        </preConditions>
        <comment>Add has_setup_page to analyzer so entity matches schema</comment>
        <addColumn tableName="analyzer">
            <column name="has_setup_page" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
