  <changeSet id="3.4.0.0-add-vec-workflow-type" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.observation_history_type WHERE type_name = 'vecWorkflowType'
      </sqlCheck>
    </preConditions>
    <insert tableName="observation_history_type" schemaName="clinlims">
      <column name="id" valueSequenceNext="observation_history_type_seq"/>
      <column name="type_name" value="vecWorkflowType"/>
      <column name="description" value="Vector surveillance workflow type marker"/>
      <column name="lastupdated" valueDate="CURRENT_TIMESTAMP"/>
    </insert>
  </changeSet>

