<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="3.4-025-add-prefer-generic-plugin" author="demo-madagascar-analyzer">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="analyzer_configuration"/>
            <not>
                <columnExists tableName="analyzer_configuration" columnName="prefer_generic_plugin"/>
            </not>
        </preConditions>
        <comment>Allow admin to prefer GenericASTM/GenericHL7 over legacy plugin when both could match</comment>

        <addColumn tableName="analyzer_configuration">
            <column name="prefer_generic_plugin" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="analyzer_configuration" columnName="prefer_generic_plugin"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
