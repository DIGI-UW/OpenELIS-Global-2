<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- IMMUNOLOGY LABORATORY SAMPLE TYPES                        -->
    <!-- Creates sample types for the immunology laboratory        -->
    <!-- Used for manifest import validation                       -->
    <!-- ======================================================== -->

    <!-- ======================================================== -->
    <!-- 1. PRIMARY BLOOD AND BLOOD DERIVATIVES                    -->
    <!-- ======================================================== -->

    <!-- Whole Blood -->
    <changeSet id="add-immuno-localization-whole-blood" author="openelis-immunology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE english = 'Whole Blood' AND description = 'sampleType name'
            </sqlCheck>
        </preConditions>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="description" value="sampleType name"/>
            <column name="english" value="Whole Blood"/>
            <column name="french" value="Sang total"/>
            <column name="lastupdated" valueComputed="${now}"/>
        </insert>
    </changeSet>

    <changeSet id="add-immuno-sample-type-whole-blood" author="openelis-immunology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.type_of_sample WHERE LOWER(description) = 'whole blood'
            </sqlCheck>
        </preConditions>
        <insert tableName="type_of_sample" schemaName="clinlims">
            <column name="id" valueSequenceNext="type_of_sample_seq"/>
            <column name="description" value="Whole Blood"/>
            <column name="domain" value="H"/>
            <column name="lastupdated" valueComputed="${now}"/>
            <column name="is_active" value="Y"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE english = 'Whole Blood' AND description = 'sampleType name')"/>
        </insert>
    </changeSet>

