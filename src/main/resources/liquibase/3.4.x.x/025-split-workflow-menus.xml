                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
        Split Workflow Menus (015)
        Replaces the unified "Add Order" menu tree with three independent workflow trees:
          - Add Clinical Order    (/order/clinical/*)
          - Add Environmental Order (/order/environmental/*)
          - Add Vector Order      (/order/vector/*)

        The old unified menu_order_workflow and its children are deactivated (not deleted)
        so that existing role-permission rows referencing those menu IDs remain intact.
    -->

    <!-- ================================================================
         1. Deactivate old unified workflow menus
         ================================================================ -->
    <changeSet id="nav-015-deactivate-old-order-workflow" author="reagan-meant">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="menu" schemaName="clinlims"/>
            <sqlCheck expectedResult="1">
                SELECT count(*) FROM clinlims.menu WHERE element_id = 'menu_order_workflow'
            </sqlCheck>
        </preConditions>
        <comment>Deactivate old unified order workflow menu and all its children</comment>
        <update tableName="menu" schemaName="clinlims">
            <column name="is_active" valueBoolean="false"/>
            <where>element_id IN (
                'menu_order_workflow',
                'menu_order_dashboard',
                'menu_order_enter',
                'menu_order_collect',
                'menu_order_label',
                'menu_order_qa'
            )</where>
        </update>
    </changeSet>

    <!-- ================================================================
         2. Shared parent: "Add Order" (expandable group, no URL)
         ================================================================ -->
    <changeSet id="nav-015-create-add-order-parent" author="reagan-meant">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="menu" schemaName="clinlims"/>
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM clinlims.menu WHERE element_id = 'menu_add_order'
            </sqlCheck>
        </preConditions>
        <comment>Create shared Add Order parent menu under Sample menu</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq"/>
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_sample')"/>
            <column name="presentation_order" valueNumeric="1"/>
            <column name="element_id" value="menu_add_order"/>
            <column name="action_url" value=""/>
            <column name="display_key" value="sidenav.label.add.order"/>
            <column name="tool_tip_key" value="sidenav.label.add.order"/>
            <column name="new_window" valueBoolean="false"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>
    </changeSet>

