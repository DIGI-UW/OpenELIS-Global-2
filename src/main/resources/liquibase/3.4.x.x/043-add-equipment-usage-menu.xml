<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add Equipment Usage menu item as child of Inventory menu -->
    <changeSet id="add-equipment-usage-menu" author="openelis">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.menu WHERE element_id = 'menu_equipment_usage';
            </sqlCheck>
        </preConditions>
        <comment>Add Equipment Usage tracking as submenu of Inventory Management</comment>
        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq" />
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_inventory')" />
            <column name="presentation_order" value="100" />
            <column name="element_id" value="menu_equipment_usage" />
            <column name="action_url" value="/equipment-usage" />
            <column name="display_key" value="sidenav.label.equipment.usage" />
            <column name="tool_tip_key" value="sidenav.label.equipment.usage.tooltip" />
            <column name="new_window" valueBoolean="false" />
            <column name="is_active" valueBoolean="true" />
            <column name="hide_in_old_ui" valueBoolean="true" />
        </insert>
    </changeSet>

</databaseChangeLog>
