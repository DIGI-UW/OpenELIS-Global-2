<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================== -->
    <!-- PHARMACEUTICALS SAMPLE TYPES                              -->
    <!-- Adds sample types used by the Pharmaceuticals manifest    -->
    <!-- ======================================================== -->

    <!-- Finished dosage form -->
    <changeSet id="add-pharma-localization-finished-dosage-form" author="openelis-pharma">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE english = 'Finished dosage form' AND description = 'sampleType name'
            </sqlCheck>
        </preConditions>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="description" value="sampleType name"/>
            <column name="english" value="Finished dosage form"/>
            <column name="french" value="Forme dosage finie"/>
            <column name="lastupdated" valueComputed="now()"/>
        </insert>
    </changeSet>

    <changeSet id="add-pharma-sample-type-finished-dosage-form" author="openelis-pharma">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.type_of_sample WHERE LOWER(description) = 'finished dosage form'
            </sqlCheck>
        </preConditions>
        <insert tableName="type_of_sample" schemaName="clinlims">
            <column name="id" valueSequenceNext="type_of_sample_seq"/>
            <column name="description" value="Finished dosage form"/>
            <column name="domain" value="H"/>
            <column name="lastupdated" valueComputed="now()"/>
            <column name="is_active" value="Y"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE english = 'Finished dosage form' AND description = 'sampleType name')"/>
        </insert>
    </changeSet>

