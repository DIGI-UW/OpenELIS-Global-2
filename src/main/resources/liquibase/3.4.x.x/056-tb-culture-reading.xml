<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- TB_CULTURE_READING TABLE -->
    <!-- Tracks weekly culture readings for up to 8 weeks -->
    <!-- One record per sample per week -->
    <!-- ======================================================== -->
    <changeSet id="create-tb-culture-reading-sequence" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="tb_culture_reading_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating sequence for tb_culture_reading table.</comment>
        <createSequence sequenceName="tb_culture_reading_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="create-tb-culture-reading-table" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating TB_CULTURE_READING table for weekly culture monitoring.</comment>
        <createTable tableName="tb_culture_reading">
            <column name="id" type="INTEGER" defaultValueSequenceNext="tb_culture_reading_seq">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_tb_culture_reading"/>
            </column>
            <column name="sample_item_id" type="NUMERIC(10)">
                <constraints nullable="false"/>
            </column>
            <column name="week_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="reading_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="culture_method" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="growth_observation" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <!-- For BOTH method, track individual media observations -->
            <column name="lj_observation" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="mgit_observation" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="read_by" type="NUMERIC(10)">
                <constraints nullable="true"/>
            </column>
            <column name="is_delayed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="add-tb-culture-reading-foreign-keys" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding foreign key constraints to tb_culture_reading table.</comment>
        <addForeignKeyConstraint
            baseTableName="tb_culture_reading"
            baseColumnNames="sample_item_id"
            referencedTableName="sample_item"
            referencedColumnNames="id"
            constraintName="fk_tb_culture_sample_item"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="tb_culture_reading"
            baseColumnNames="read_by"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_tb_culture_read_by"/>
    </changeSet>

    <changeSet id="add-tb-culture-reading-unique-constraint" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding unique constraint for sample_item_id + week_number (one reading per week).</comment>
        <addUniqueConstraint
            tableName="tb_culture_reading"
            columnNames="sample_item_id, week_number"
            constraintName="uq_tb_culture_sample_week"/>
    </changeSet>

    <changeSet id="add-tb-culture-reading-week-number-check" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for week_number (1-8).</comment>
        <sql>
            ALTER TABLE clinlims.tb_culture_reading
            ADD CONSTRAINT chk_tb_culture_week_number
            CHECK (week_number >= 1 AND week_number &lt;= 8);
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.tb_culture_reading DROP CONSTRAINT IF EXISTS chk_tb_culture_week_number;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-tb-culture-reading-method-check" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for culture_method values.</comment>
        <sql>
            ALTER TABLE clinlims.tb_culture_reading
            ADD CONSTRAINT chk_tb_culture_method
            CHECK (culture_method IN ('LJ', 'MGIT', 'BOTH'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.tb_culture_reading DROP CONSTRAINT IF EXISTS chk_tb_culture_method;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-tb-culture-reading-observation-check" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Adding CHECK constraint for growth_observation values.</comment>
        <sql>
            ALTER TABLE clinlims.tb_culture_reading
            ADD CONSTRAINT chk_tb_culture_observation
            CHECK (growth_observation IN ('NO_GROWTH', 'GROWTH_DETECTED', 'CONTAMINATED'));
        </sql>
        <rollback>
            <sql>ALTER TABLE clinlims.tb_culture_reading DROP CONSTRAINT IF EXISTS chk_tb_culture_observation;</sql>
        </rollback>
    </changeSet>

    <changeSet id="add-tb-culture-reading-indexes" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tb_culture_reading" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for query optimization.</comment>
        <createIndex tableName="tb_culture_reading" indexName="idx_tb_culture_sample_week">
            <column name="sample_item_id"/>
            <column name="week_number"/>
        </createIndex>
        <createIndex tableName="tb_culture_reading" indexName="idx_tb_culture_observation">
            <column name="growth_observation"/>
        </createIndex>
        <createIndex tableName="tb_culture_reading" indexName="idx_tb_culture_reading_date">
            <column name="reading_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="create-tb-culture-reading-reference-table" author="openelis-tb">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.reference_tables WHERE name = 'TB_CULTURE_READING'
            </sqlCheck>
        </preConditions>
        <comment>Creating TB_CULTURE_READING reference table entry for audit trail tracking.</comment>
        <insert tableName="reference_tables" schemaName="clinlims">
            <column name="id" valueSequenceNext="reference_tables_seq"/>
            <column name="name" value="TB_CULTURE_READING"/>
            <column name="keep_history" value="Y"/>
            <column name="is_hl7_encoded" value="N"/>
            <column name="lastupdated" valueComputed="${now}"/>
        </insert>
        <rollback>
            <delete schemaName="clinlims" tableName="reference_tables">
                <where>name='TB_CULTURE_READING'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
