<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- MNTD DEPARTMENT AND COMPREHENSIVE SAMPLE TYPES           -->
    <!-- Creates:                                                  -->
    <!-- 1. MNTD test_section (department)                        -->
    <!-- 2. Comprehensive sample types for MNTD lab               -->
    <!-- 3. Links notebook template to the department             -->
    <!-- ======================================================== -->

    <!-- ======================================================== -->
    <!-- 1. CREATE MNTD DEPARTMENT (TEST_SECTION)                 -->
    <!-- ======================================================== -->
    <changeSet id="create-mntd-localization-test-section" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE description = 'mntd test section' AND english = 'MNTD'
            </sqlCheck>
        </preConditions>
        <comment>Create localization entry for MNTD test section</comment>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="lastupdated" valueComputed="${now}"/>
            <column name="description" value="mntd test section"/>
            <column name="english" value="MNTD"/>
            <column name="french" value="MNTD"/>
        </insert>
    </changeSet>

    <changeSet id="create-mntd-test-section" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.test_section WHERE name = 'MNTD'
            </sqlCheck>
        </preConditions>
        <comment>Create MNTD test section (department)</comment>
        <insert tableName="test_section" schemaName="clinlims">
            <column name="id" valueSequenceNext="test_section_seq"/>
            <column name="name" value="MNTD"/>
            <column name="description" value="Malaria and NTD Laboratory"/>
            <column name="is_external" value="N"/>
            <column name="lastupdated" valueComputed="${now}"/>
            <column name="sort_order" value="2147483647"/>
            <column name="is_active" value="Y"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE description = 'mntd test section' AND english = 'MNTD' LIMIT 1)"/>
            <column name="display_key" value="testsection.MNTD"/>
        </insert>
    </changeSet>

