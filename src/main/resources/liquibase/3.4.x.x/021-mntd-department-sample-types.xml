    <!-- ======================================================== -->
    <!-- 4. LINK MNTD NOTEBOOK TO DEPARTMENT                      -->
    <!-- ======================================================== -->
    <changeSet id="link-mntd-notebook-to-department" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_departments" schemaName="clinlims"/>
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.notebook WHERE title = 'MNTD Laboratory' AND is_template = true
            </sqlCheck>
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.test_section WHERE name = 'MNTD'
            </sqlCheck>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.notebook_departments nd
                JOIN clinlims.notebook n ON nd.notebook_id = n.id
                JOIN clinlims.test_section ts ON nd.test_section_id = ts.id
                WHERE n.title = 'MNTD Laboratory' AND ts.name = 'MNTD'
            </sqlCheck>
        </preConditions>
        <comment>Link MNTD Laboratory notebook template to MNTD department</comment>
        <sql>
            INSERT INTO clinlims.notebook_departments (notebook_id, test_section_id)
            SELECT n.id, ts.id
            FROM clinlims.notebook n, clinlims.test_section ts
            WHERE n.title = 'MNTD Laboratory'
              AND n.is_template = true
              AND ts.name = 'MNTD';
        </sql>
    </changeSet>

    <!-- ======================================================== -->
    <!-- 5. ENSURE MNTD NOTEBOOK HAS ALL ACTIVE ORGANIZATIONS     -->
    <!-- ======================================================== -->
    <changeSet id="backfill-mntd-notebook-organizations" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_organizations" schemaName="clinlims"/>
            <tableExists tableName="notebook" schemaName="clinlims"/>
            <tableExists tableName="organization" schemaName="clinlims"/>
        </preConditions>
        <comment>Ensure MNTD Laboratory notebook has all active organizations assigned.</comment>
        <sql>
            INSERT INTO clinlims.notebook_organizations (notebook_id, organization_id)
            SELECT n.id, o.id
            FROM clinlims.notebook n
            CROSS JOIN clinlims.organization o
            WHERE n.title = 'MNTD Laboratory'
              AND n.is_template = true
              AND o.is_active = 'Y'
              AND NOT EXISTS (
                  SELECT 1 FROM clinlims.notebook_organizations no
                  WHERE no.notebook_id = n.id AND no.organization_id = o.id
              );
        </sql>
    </changeSet>

