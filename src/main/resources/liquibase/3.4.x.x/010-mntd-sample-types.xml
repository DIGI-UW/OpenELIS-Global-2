<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================== -->
    <!-- MNTD SAMPLE TYPES -->
    <!-- Adds sample types required for MNTD Laboratory workflow -->
    <!-- Each sample type requires a localization entry first -->
    <!-- ======================================================== -->

    <!-- Cell pellet -->
    <changeSet id="add-mntd-localization-cell-pellet" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE english = 'Cell pellet' AND description = 'sampleType name'
            </sqlCheck>
        </preConditions>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="description" value="sampleType name"/>
            <column name="english" value="Cell pellet"/>
            <column name="french" value="Culot cellulaire"/>
            <column name="lastupdated" valueComputed="now()"/>
        </insert>
    </changeSet>

    <changeSet id="add-mntd-sample-type-cell-pellet" author="openelis-mntd">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.type_of_sample WHERE LOWER(description) = 'cell pellet'
            </sqlCheck>
        </preConditions>
        <insert tableName="type_of_sample" schemaName="clinlims">
            <column name="id" valueSequenceNext="type_of_sample_seq"/>
            <column name="description" value="Cell pellet"/>
            <column name="domain" value="H"/>
            <column name="lastupdated" valueComputed="now()"/>
            <column name="is_active" value="Y"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE english = 'Cell pellet' AND description = 'sampleType name')"/>
        </insert>
    </changeSet>

