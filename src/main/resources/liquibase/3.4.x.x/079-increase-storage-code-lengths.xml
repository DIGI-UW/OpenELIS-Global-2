<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================== -->
    <!-- STORAGE CODE COLUMN LENGTH INCREASES -->
    <!-- Increases character limits for storage entity code columns -->
    <!-- Required for hierarchical storage naming schemes -->
    <!-- ======================================================== -->

    <changeSet id="increase-storage-room-code-length" author="openelis-storage-config">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="storage_room" schemaName="clinlims"/>
            <columnExists tableName="storage_room" columnName="code" schemaName="clinlims"/>
        </preConditions>
        <comment>Increase storage_room.code column length from 10 to 50 characters</comment>
        <modifyDataType tableName="storage_room" columnName="code" newDataType="CHARACTER VARYING(50)" schemaName="clinlims"/>
    </changeSet>

    <changeSet id="increase-storage-device-code-length" author="openelis-storage-config">
