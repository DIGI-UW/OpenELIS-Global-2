<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ========================================================= -->
    <!-- Panel LOINC Code (verify / add if missing)                -->
    <!-- ========================================================= -->
    <changeSet id="panel-001-add-loinc-code" author="Agaba-Derrick">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="panel" columnName="loinc"/>
            </not>
        </preConditions>
        <addColumn tableName="panel">
            <column name="loinc" type="varchar(20)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="panel" columnName="loinc"/>
        </rollback>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Panel ↔ Lab Unit Mapping Table                            -->
    <!-- ========================================================= -->
    <changeSet id="panel-002-create-panel-lab-unit" author="Agaba-Derrick">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="panel_lab_unit"/>
            </not>
        </preConditions>
        <createTable tableName="panel_lab_unit">
            <column name="id" type="numeric(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="panel_id" type="numeric(10,0)">
                <constraints nullable="false"
                             referencedTableName="panel"
                             referencedColumnNames="id"
                             foreignKeyName="fk_panel_lab_unit_panel"/>
            </column>
            <column name="lab_unit_id" type="numeric(10,0)">
                <constraints nullable="false"
                             referencedTableName="lab_unit"
                             referencedColumnNames="id"
                             foreignKeyName="fk_panel_lab_unit_lab_unit"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="panel_lab_unit"
                columnNames="panel_id, lab_unit_id"
                constraintName="uq_panel_lab_unit"/>

        <rollback>
            <dropTable tableName="panel_lab_unit"/>
        </rollback>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Panel ↔ Sample Type Mapping (existing table hardening)    -->
    <!-- ========================================================= -->
    <changeSet id="panel-003-add-unique-sampletype-panel" author="Agaba-Derrick">
        <addUniqueConstraint
                tableName="sampletype_panel"
                columnNames="panel_id, sample_type_id"
                constraintName="uq_sampletype_panel"/>
        <rollback>
            <dropUniqueConstraint
                    tableName="sampletype_panel"
                    constraintName="uq_sampletype_panel"/>
        </rollback>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Panel Item (Panel Test) Enhancements                      -->
    <!-- ========================================================= -->
    <changeSet id="panel-004-add-panel-item-loinc" author="Agaba-Derrick">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="panel_item" columnName="panel_loinc_code"/>
            </not>
        </preConditions>
        <addColumn tableName="panel_item">
            <column name="panel_loinc_code" type="varchar(20)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="panel_item" columnName="panel_loinc_code"/>
        </rollback>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Panel Import Log                                          -->
    <!-- ========================================================= -->
    <changeSet id="panel-005-create-import-log" author="Agaba-Derrick">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="panel_import_log"/>
            </not>
        </preConditions>
        <createTable tableName="panel_import_log">
            <column name="id" type="numeric(10,0)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="import_date" type="timestamp"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="imported_by" type="numeric(10,0)">
                <constraints referencedTableName="system_user"
                             referencedColumnNames="id"
                             foreignKeyName="fk_panel_import_user"/>
            </column>
            <column name="file_name" type="varchar(255)"/>
            <column name="panels_created" type="integer" defaultValueNumeric="0"/>
            <column name="panels_updated" type="integer" defaultValueNumeric="0"/>
            <column name="panels_skipped" type="integer" defaultValueNumeric="0"/>
            <column name="warnings" type="text"/>
            <column name="import_data" type="jsonb"/>
        </createTable>
        <rollback>
            <dropTable tableName="panel_import_log"/>
        </rollback>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Indexes                                                   -->
    <!-- ========================================================= -->
    <changeSet id="panel-006-create-indexes" author="Agaba-Derrick">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_panel_lab_unit_panel"/>
            </not>
        </preConditions>

        <createIndex indexName="idx_panel_lab_unit_panel" tableName="panel_lab_unit">
            <column name="panel_id"/>
        </createIndex>

        <createIndex indexName="idx_panel_lab_unit_lab_unit" tableName="panel_lab_unit">
            <column name="lab_unit_id"/>
        </createIndex>

        <createIndex indexName="idx_sampletype_panel_panel" tableName="sampletype_panel">
            <column name="panel_id"/>
        </createIndex>

        <createIndex indexName="idx_panel_item_panel" tableName="panel_item">
            <column name="panel_id"/>
        </createIndex>

        <createIndex indexName="idx_panel_item_sort_order" tableName="panel_item">
            <column name="panel_id"/>
            <column name="sort_order"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_panel_lab_unit_panel" tableName="panel_lab_unit"/>
            <dropIndex indexName="idx_panel_lab_unit_lab_unit" tableName="panel_lab_unit"/>
            <dropIndex indexName="idx_sampletype_panel_panel" tableName="sampletype_panel"/>
            <dropIndex indexName="idx_panel_item_panel" tableName="panel_item"/>
            <dropIndex indexName="idx_panel_item_sort_order" tableName="panel_item"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
