<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================================= -->
    <!-- CREATE TRADITIONAL MEDICINE LAB UNIT                                   -->
    <!-- Creates lab unit for TMMRD roles so admin users get automatic access   -->
    <!-- ======================================================================= -->

    <!-- Create the Traditional Medicine lab unit -->
    <changeSet id="create-tradmed-lab-unit" author="openelis-admin-access">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="lab_unit_role_map" schemaName="clinlims"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine'
            </sqlCheck>
        </preConditions>
        <comment>Create Traditional Medicine lab unit to enable admin access to TMMRD roles</comment>
        <insert tableName="lab_unit_role_map" schemaName="clinlims">
            <column name="lab_unit" value="TraditionalMedicine"/>
        </insert>
    </changeSet>

    <!-- Assign all 5 TMMRD roles to the Traditional Medicine lab unit -->
    <changeSet id="assign-tradmed-roles-to-lab-unit" author="openelis-admin-access">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="lab_roles" schemaName="clinlims"/>
            <sqlCheck expectedResult="1">
                SELECT COUNT(*) FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine'
            </sqlCheck>
            <sqlCheck expectedResult="5">
                SELECT COUNT(*) FROM clinlims.system_role
                WHERE name IN ('TMMRD Lab Technician', 'TMMRD Researcher', 'TMMRD Pharmacognosist', 'TMMRD Lab Manager', 'TMMRD Principal Investigator')
            </sqlCheck>
        </preConditions>
        <comment>Assign all TMMRD roles to Traditional Medicine lab unit</comment>

        <!-- TMMRD Lab Technician -->
        <insert tableName="lab_roles" schemaName="clinlims">
            <column name="lab_unit_role_map_id" valueComputed="(SELECT lab_unit_role_map_id FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine')"/>
            <column name="role" valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'TMMRD Lab Technician')"/>
        </insert>

        <!-- TMMRD Researcher -->
        <insert tableName="lab_roles" schemaName="clinlims">
            <column name="lab_unit_role_map_id" valueComputed="(SELECT lab_unit_role_map_id FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine')"/>
            <column name="role" valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'TMMRD Researcher')"/>
        </insert>

        <!-- TMMRD Pharmacognosist -->
        <insert tableName="lab_roles" schemaName="clinlims">
            <column name="lab_unit_role_map_id" valueComputed="(SELECT lab_unit_role_map_id FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine')"/>
            <column name="role" valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'TMMRD Pharmacognosist')"/>
        </insert>

        <!-- TMMRD Lab Manager -->
        <insert tableName="lab_roles" schemaName="clinlims">
            <column name="lab_unit_role_map_id" valueComputed="(SELECT lab_unit_role_map_id FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine')"/>
            <column name="role" valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'TMMRD Lab Manager')"/>
        </insert>

        <!-- TMMRD Principal Investigator -->
        <insert tableName="lab_roles" schemaName="clinlims">
            <column name="lab_unit_role_map_id" valueComputed="(SELECT lab_unit_role_map_id FROM clinlims.lab_unit_role_map WHERE lab_unit = 'TraditionalMedicine')"/>
            <column name="role" valueComputed="(SELECT id FROM clinlims.system_role WHERE name = 'TMMRD Principal Investigator')"/>
        </insert>
    </changeSet>

</databaseChangeLog>
