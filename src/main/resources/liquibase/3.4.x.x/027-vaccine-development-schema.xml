<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- VACCINE DEVELOPMENT WORKFLOW DATABASE SCHEMA -->
    <!-- ======================================================== -->
    <!--
    This changeset creates comprehensive database support for the
    Vaccine Development workflow (Stage 3 of Virology & Vaccine Unit).

    Covers 5 vaccine development stages per PDF requirements:
    1. Virus Isolation - Link to culture batch
    2. Titer Measurement - TCID50, PFU/ml values
    3. Genome Sequencing - FASTA uploads, GenBank accessions
    4. Seed Virus Production - Selection criteria, batch tracking
    5. Preclinical Trials - Animal testing tracking (external)
    -->
    <!-- ======================================================== -->

    <!-- Main vaccine development entry table -->
    <changeSet id="create-vaccine-development-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_development" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create main vaccine development tracking table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_development">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fhir_uuid" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="notebook_entry_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="development_stage" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="stage_status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="started_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="completed_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="created_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INTEGER" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_development"
            baseColumnNames="notebook_entry_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="notebook_entry"
            referencedColumnNames="id"
            constraintName="fk_vaccine_development_notebook_entry"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_development"
            baseColumnNames="created_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_vaccine_development_created_by"/>

        <createIndex schemaName="clinlims" tableName="vaccine_development" indexName="idx_vaccine_dev_notebook_entry">
            <column name="notebook_entry_id"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_development" indexName="idx_vaccine_dev_stage">
            <column name="development_stage"/>
        </createIndex>

        <sql>
            ALTER TABLE clinlims.vaccine_development
            ADD CONSTRAINT chk_development_stage
            CHECK (development_stage IN ('VIRUS_ISOLATION', 'TITER_MEASUREMENT', 'GENOME_SEQUENCING', 'SEED_VIRUS_PRODUCTION', 'PRECLINICAL_TRIALS'));

            ALTER TABLE clinlims.vaccine_development
            ADD CONSTRAINT chk_stage_status
            CHECK (stage_status IN ('PENDING', 'IN_PROGRESS', 'COMPLETED', 'FAILED', 'ON_HOLD'));
        </sql>
    </changeSet>

    <!-- Virus Isolation data table -->
    <changeSet id="create-virus-isolation-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_virus_isolation" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create virus isolation data table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_virus_isolation">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vaccine_development_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="culture_batch_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="isolation_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="isolation_method" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="isolation_notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="performed_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_virus_isolation"
            baseColumnNames="vaccine_development_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="vaccine_development"
            referencedColumnNames="id"
            constraintName="fk_virus_isolation_vaccine_dev"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_virus_isolation"
            baseColumnNames="culture_batch_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="virus_culture_batch"
            referencedColumnNames="id"
            constraintName="fk_virus_isolation_culture_batch"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_virus_isolation"
            baseColumnNames="performed_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_virus_isolation_performed_by"/>
    </changeSet>

    <!-- Titer Measurement data table -->
    <changeSet id="create-titer-measurement-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_titer_measurement" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create titer measurement data table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_titer_measurement">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vaccine_development_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="measurement_method" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tcid50_value" type="DECIMAL(15,2)">
                <constraints nullable="true"/>
            </column>
            <column name="pfu_ml_value" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="ha_titer" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="qpcr_ct_value" type="DECIMAL(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="other_value" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="measurement_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="dilution_series" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="assay_conditions" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="performed_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="validated_by" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_titer_measurement"
            baseColumnNames="vaccine_development_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="vaccine_development"
            referencedColumnNames="id"
            constraintName="fk_titer_measurement_vaccine_dev"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_titer_measurement"
            baseColumnNames="performed_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_titer_measurement_performed_by"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_titer_measurement"
            baseColumnNames="validated_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_titer_measurement_validated_by"/>

        <sql>
            ALTER TABLE clinlims.vaccine_titer_measurement
            ADD CONSTRAINT chk_measurement_method
            CHECK (measurement_method IN ('TCID50', 'PFU_ML', 'HA', 'QPCR', 'OTHER'));
        </sql>
    </changeSet>

    <!-- Genome Sequencing data table -->
    <changeSet id="create-genome-sequencing-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_genome_sequencing" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create genome sequencing data table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_genome_sequencing">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vaccine_development_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sequencing_platform" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="sequencing_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="fasta_file_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="fasta_file_path" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="fasta_file_size" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="genbank_accession" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="genome_length" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="sequence_quality_score" type="DECIMAL(5,2)">
                <constraints nullable="true"/>
            </column>
            <column name="coverage_depth" type="DECIMAL(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="analysis_results" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="phylogenetic_analysis" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="mutation_summary" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="performed_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="analyzed_by" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_genome_sequencing"
            baseColumnNames="vaccine_development_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="vaccine_development"
            referencedColumnNames="id"
            constraintName="fk_genome_sequencing_vaccine_dev"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_genome_sequencing"
            baseColumnNames="performed_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_genome_sequencing_performed_by"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_genome_sequencing"
            baseColumnNames="analyzed_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_genome_sequencing_analyzed_by"/>
    </changeSet>

    <!-- Seed Virus Production data table -->
    <changeSet id="create-seed-virus-production-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_seed_virus_production" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create seed virus production data table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_seed_virus_production">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vaccine_development_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="seed_batch_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="seed_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_virus_strain" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="passage_level" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="production_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="production_method" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="selection_criteria" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="genetic_stability_data" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="immunogenicity_data" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="safety_profile" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="storage_conditions" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="expiration_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="produced_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="approved_by" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_seed_virus_production"
            baseColumnNames="vaccine_development_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="vaccine_development"
            referencedColumnNames="id"
            constraintName="fk_seed_virus_production_vaccine_dev"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_seed_virus_production"
            baseColumnNames="produced_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_seed_virus_production_produced_by"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_seed_virus_production"
            baseColumnNames="approved_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_seed_virus_production_approved_by"/>

        <sql>
            ALTER TABLE clinlims.vaccine_seed_virus_production
            ADD CONSTRAINT chk_seed_type
            CHECK (seed_type IN ('MASTER', 'WORKING', 'PRODUCTION'));
        </sql>
    </changeSet>

    <!-- Preclinical Trials data table -->
    <changeSet id="create-preclinical-trials-table" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vaccine_preclinical_trials" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create preclinical trials data table</comment>

        <createTable schemaName="clinlims" tableName="vaccine_preclinical_trials">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="vaccine_development_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trial_protocol_id" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="initiation_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="estimated_completion_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="actual_completion_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="animal_species" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="animal_count" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="animal_age_weeks" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="trial_status" type="VARCHAR(20)" defaultValue="PLANNED">
                <constraints nullable="false"/>
            </column>
            <column name="trial_objectives" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="vaccination_protocol" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="immunogenicity_outcomes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="safety_outcomes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="adverse_events" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="efficacy_data" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="external_lab_name" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="principal_investigator" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="ethics_approval_number" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="initiated_by" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="monitored_by" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_preclinical_trials"
            baseColumnNames="vaccine_development_id"
            referencedTableSchemaName="clinlims"
            referencedTableName="vaccine_development"
            referencedColumnNames="id"
            constraintName="fk_preclinical_trials_vaccine_dev"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_preclinical_trials"
            baseColumnNames="initiated_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_preclinical_trials_initiated_by"/>

        <addForeignKeyConstraint
            baseTableSchemaName="clinlims"
            baseTableName="vaccine_preclinical_trials"
            baseColumnNames="monitored_by"
            referencedTableSchemaName="clinlims"
            referencedTableName="system_user"
            referencedColumnNames="id"
            constraintName="fk_preclinical_trials_monitored_by"/>

        <sql>
            ALTER TABLE clinlims.vaccine_preclinical_trials
            ADD CONSTRAINT chk_animal_species
            CHECK (animal_species IN ('MICE', 'RATS', 'RABBITS', 'NHP', 'FERRETS', 'OTHER'));

            ALTER TABLE clinlims.vaccine_preclinical_trials
            ADD CONSTRAINT chk_trial_status
            CHECK (trial_status IN ('PLANNED', 'IN_PROGRESS', 'COMPLETED', 'ON_HOLD', 'TERMINATED'));
        </sql>
    </changeSet>

    <!-- Add additional indexes for performance -->
    <changeSet id="create-vaccine-development-indexes" author="openelis-virology">
        <comment>Create additional indexes for vaccine development queries</comment>

        <createIndex schemaName="clinlims" tableName="vaccine_virus_isolation" indexName="idx_virus_isolation_culture_batch">
            <column name="culture_batch_id"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_titer_measurement" indexName="idx_titer_measurement_method">
            <column name="measurement_method"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_genome_sequencing" indexName="idx_genome_sequencing_genbank">
            <column name="genbank_accession"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_seed_virus_production" indexName="idx_seed_virus_batch_id">
            <column name="seed_batch_id"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_preclinical_trials" indexName="idx_preclinical_trials_status">
            <column name="trial_status"/>
        </createIndex>

        <createIndex schemaName="clinlims" tableName="vaccine_preclinical_trials" indexName="idx_preclinical_trials_species">
            <column name="animal_species"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>