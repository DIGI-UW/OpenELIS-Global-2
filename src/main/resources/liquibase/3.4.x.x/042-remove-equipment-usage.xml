<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Remove menu entry for equipment management -->
    <changeSet id="remove-equipment-menu" author="openelis">
        <delete tableName="menu">
            <where>element_id = 'menu_equipment_management'</where>
        </delete>
    </changeSet>

    <!-- Remove reference_tables entries for audit trail -->
    <changeSet id="remove-equipment-audit-references" author="openelis">
        <delete tableName="reference_tables">
            <where>name IN ('EQUIPMENT', 'EQUIPMENT_USAGE_ENTRY')</where>
        </delete>
    </changeSet>

    <!-- Drop foreign keys first (prevents constraint violations) -->
    <changeSet id="drop-equipment-foreign-keys" author="openelis">
        <dropForeignKeyConstraint baseTableName="equipment_usage_audit"
                                  constraintName="equipment_usage_audit_usage_entry_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_audit"
                                  constraintName="equipment_usage_audit_created_by_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_entry"
                                  constraintName="equipment_usage_entry_equipment_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_entry"
                                  constraintName="equipment_usage_entry_operator_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_entry"
                                  constraintName="equipment_usage_entry_approved_by_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_entry"
                                  constraintName="equipment_usage_entry_created_by_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment_usage_entry"
                                  constraintName="equipment_usage_entry_modified_by_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment"
                                  constraintName="equipment_created_by_fk"/>
        <dropForeignKeyConstraint baseTableName="equipment"
                                  constraintName="equipment_modified_by_fk"/>
    </changeSet>

    <!-- Drop tables in reverse order of creation -->
    <changeSet id="drop-equipment-usage-audit-table" author="openelis">
        <dropTable tableName="equipment_usage_audit"/>
        <dropSequence sequenceName="equipment_usage_audit_seq"/>
    </changeSet>

    <changeSet id="drop-equipment-usage-entry-table" author="openelis">
        <dropTable tableName="equipment_usage_entry"/>
        <dropSequence sequenceName="equipment_usage_entry_seq"/>
    </changeSet>

    <changeSet id="drop-equipment-table" author="openelis">
        <dropTable tableName="equipment"/>
        <dropSequence sequenceName="equipment_seq"/>
    </changeSet>

</databaseChangeLog>
