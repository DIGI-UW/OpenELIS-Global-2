      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- VIROLOGY & VACCINE UNIT SAMPLE TYPES                      -->
    <!-- Creates sample types for the virology laboratory          -->
    <!-- Used for manifest import validation                       -->
    <!-- ======================================================== -->

