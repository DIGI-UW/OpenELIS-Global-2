    <!-- ======================================================== -->

    <!-- Nasal Swab -->
    <changeSet id="add-virology-localization-nasal-swab" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE english = 'Nasal Swab' AND description = 'sampleType name'
            </sqlCheck>
        </preConditions>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="description" value="sampleType name"/>
            <column name="english" value="Nasal Swab"/>
            <column name="french" value="Ecouvillon nasal"/>
            <column name="lastupdated" valueComputed="${now}"/>
        </insert>
    </changeSet>

    <changeSet id="add-virology-sample-type-nasal-swab" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.type_of_sample WHERE LOWER(description) = 'nasal swab'
            </sqlCheck>
        </preConditions>
        <insert tableName="type_of_sample" schemaName="clinlims">
            <column name="id" valueSequenceNext="type_of_sample_seq"/>
            <column name="description" value="Nasal Swab"/>
            <column name="domain" value="H"/>
            <column name="lastupdated" valueComputed="${now}"/>
            <column name="is_active" value="Y"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE english = 'Nasal Swab' AND description = 'sampleType name')"/>
        </insert>
    </changeSet>

