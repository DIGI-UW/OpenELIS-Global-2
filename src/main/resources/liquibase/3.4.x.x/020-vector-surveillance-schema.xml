    </sql>
  </changeSet>

  <changeSet id="3.4.0.0-seed-vector-trap-ovitrap" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.vector_trap_type WHERE name = 'Ovitrap'
      </sqlCheck>
    </preConditions>
    <sql>
      INSERT INTO clinlims.vector_trap_type (id, name, description, active, sys_user_id, lastupdated)
