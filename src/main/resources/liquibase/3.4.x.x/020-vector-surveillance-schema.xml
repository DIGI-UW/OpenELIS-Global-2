      <column name="description" value="Rodent hosts for vector-borne diseases"/>
      <column name="is_system" valueBoolean="false"/>
      <column name="active" valueBoolean="true"/>
      <column name="sys_user_id" value="1"/>
      <column name="lastupdated" valueDate="CURRENT_TIMESTAMP"/>
    </insert>
  </changeSet>

  <!-- Seed: Trap Types -->
  <changeSet id="3.4.0.0-seed-vector-trap-bg-sentinel" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.vector_trap_type WHERE name = 'BG-Sentinel Trap'
      </sqlCheck>
    </preConditions>
    <sql>
      INSERT INTO clinlims.vector_trap_type (id, name, group_id, description, active, sys_user_id, lastupdated)
      SELECT nextval('clinlims.vector_trap_type_seq'), 'BG-Sentinel Trap', id,
             'CO2-baited adult mosquito trap; widely used for Aedes surveillance', true, '1', NOW()
      FROM clinlims.vector_organism_group WHERE code = 'MOSQUITO'
    </sql>
  </changeSet>

