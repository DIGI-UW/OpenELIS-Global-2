<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <!-- Vector Organism Groups -->
  <changeSet id="3.4.0.0-create-vector-organism-group-seq" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <sequenceExists sequenceName="vector_organism_group_seq" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createSequence sequenceName="vector_organism_group_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="3.4.0.0-create-vector-organism-group-table" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="vector_organism_group" schemaName="clinlims"/>
      </not>
    </preConditions>
    <comment>Organism groups for vector surveillance (Mosquito, Fly, Flea, Rodent)</comment>
    <createTable tableName="vector_organism_group" schemaName="clinlims">
      <column name="id" type="NUMERIC(10,0)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="code" type="VARCHAR(20)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="label" type="VARCHAR(60)">
        <constraints nullable="false"/>
      </column>
      <column name="color_tag" type="VARCHAR(30)"/>
      <column name="description" type="VARCHAR(255)"/>
      <column name="is_system" type="BOOLEAN" defaultValueBoolean="false"/>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="sys_user_id" type="VARCHAR(255)"/>
      <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>

  <!-- Vector Trap Types -->
  <changeSet id="3.4.0.0-create-vector-trap-type-seq" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <sequenceExists sequenceName="vector_trap_type_seq" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createSequence sequenceName="vector_trap_type_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="3.4.0.0-create-vector-trap-type-table" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="vector_trap_type" schemaName="clinlims"/>
      </not>
    </preConditions>
    <comment>Trap types for vector collection, linked to an organism group</comment>
    <createTable tableName="vector_trap_type" schemaName="clinlims">
      <column name="id" type="NUMERIC(10,0)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="group_id" type="NUMERIC(10,0)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="VARCHAR(255)"/>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="sys_user_id" type="VARCHAR(255)"/>
      <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
    <addForeignKeyConstraint
      baseTableSchemaName="clinlims"
      baseTableName="vector_trap_type"
      baseColumnNames="group_id"
      constraintName="fk_vector_trap_type_group"
      referencedTableSchemaName="clinlims"
      referencedTableName="vector_organism_group"
      referencedColumnNames="id"/>
  </changeSet>

  <!-- Vector Species -->
  <changeSet id="3.4.0.0-create-vector-species-seq" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <sequenceExists sequenceName="vector_species_seq" schemaName="clinlims"/>
      </not>
    </preConditions>
    <createSequence sequenceName="vector_species_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>
  </changeSet>

  <changeSet id="3.4.0.0-create-vector-species-table" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="vector_species" schemaName="clinlims"/>
      </not>
    </preConditions>
    <comment>Vector species with genus/species/subspecies, pathogens of interest, and lifecycle stages</comment>
    <createTable tableName="vector_species" schemaName="clinlims">
      <column name="id" type="NUMERIC(10,0)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="genus" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="species" type="VARCHAR(100)"/>
      <column name="subspecies" type="VARCHAR(100)"/>
      <column name="group_id" type="NUMERIC(10,0)">
        <constraints nullable="false"/>
      </column>
      <column name="pathogens_of_interest" type="VARCHAR(255)"/>
      <column name="lifecycle_stages" type="VARCHAR(100)"/>
      <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="sys_user_id" type="VARCHAR(255)"/>
      <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
    <addForeignKeyConstraint
      baseTableSchemaName="clinlims"
      baseTableName="vector_species"
      baseColumnNames="group_id"
      constraintName="fk_vector_species_group"
      referencedTableSchemaName="clinlims"
      referencedTableName="vector_organism_group"
      referencedColumnNames="id"/>
  </changeSet>

  <!-- Seed: Organism Groups -->
  <changeSet id="3.4.0.0-seed-vector-group-mosquito" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.vector_organism_group WHERE code = 'MOSQUITO'
      </sqlCheck>
    </preConditions>
    <insert tableName="vector_organism_group" schemaName="clinlims">
      <column name="id" valueSequenceNext="vector_organism_group_seq"/>
      <column name="code" value="MOSQUITO"/>
      <column name="label" value="Mosquito"/>
      <column name="color_tag" value="green"/>
      <column name="description" value="Culicidae family; arbovirus and malaria vectors"/>
      <column name="is_system" valueBoolean="true"/>
      <column name="active" valueBoolean="true"/>
      <column name="sys_user_id" value="1"/>
      <column name="lastupdated" valueDate="CURRENT_TIMESTAMP"/>
    </insert>
  </changeSet>

