  <!-- Seed: Species -->
  <changeSet id="3.4.0.0-seed-vector-species-aedes-aegypti" author="reagan-meant">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM clinlims.vector_species WHERE genus = 'Aedes' AND species = 'aegypti'
      </sqlCheck>
    </preConditions>
    <sql>
      INSERT INTO clinlims.vector_species (id, genus, species, subspecies, group_id, pathogens_of_interest, lifecycle_stages, active, sys_user_id, lastupdated)
      SELECT nextval('clinlims.vector_species_seq'), 'Aedes', 'aegypti', null, id,
             'Dengue,Zika,Chikungunya', 'ADULT,LARVA,PUPA,EGG', true, '1', NOW()
      FROM clinlims.vector_organism_group WHERE code = 'MOSQUITO'
