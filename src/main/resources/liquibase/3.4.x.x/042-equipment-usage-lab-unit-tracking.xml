<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="add-lab-unit-tracking-to-inventory-usage" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="clinlims" tableName="inventory_usage" columnName="lab_unit_id"/>
            </not>
        </preConditions>
        <comment>Add lab_unit_id column to inventory_usage table for tracking which laboratory/department used the equipment</comment>

        <addColumn schemaName="clinlims" tableName="inventory_usage">
            <column name="lab_unit_id" type="VARCHAR(20)" remarks="Foreign key to test_section table representing the lab unit/department that used the equipment">
                <constraints nullable="true"
                             foreignKeyName="fk_usage_lab_unit"
                             references="clinlims.test_section(id)"
                             deleteCascade="false"/>
            </column>
        </addColumn>

        <createIndex indexName="idx_usage_lab_unit" tableName="inventory_usage" schemaName="clinlims">
            <column name="lab_unit_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
