<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ======================================================== -->
    <!-- PATHOLOGY LABORATORY SAMPLE TYPES -->
    <!-- Defines specimen types specific to pathology workflows -->
    <!-- Each sample type requires a localization entry first -->
    <!-- ======================================================== -->

    <!-- ======================= -->
    <!-- HISTOPATHOLOGY SAMPLES -->
    <!-- ======================= -->

    <!-- FFPE tissue block -->
    <changeSet id="add-pathology-localization-ffpe-block" author="openelis-pathology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.localization WHERE english = 'FFPE tissue block' AND description = 'sampleType name'
            </sqlCheck>
        </preConditions>
        <insert tableName="localization" schemaName="clinlims">
            <column name="id" valueSequenceNext="localization_seq"/>
            <column name="description" value="sampleType name"/>
            <column name="english" value="FFPE tissue block"/>
            <column name="french" value="Bloc tissulaire FFPE"/>
            <column name="lastupdated" valueComputed="now()"/>
        </insert>
    </changeSet>

    <changeSet id="add-pathology-sample-type-ffpe-block" author="openelis-pathology">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.type_of_sample WHERE LOWER(description) = 'ffpe tissue block'
            </sqlCheck>
        </preConditions>
        <insert tableName="type_of_sample" schemaName="clinlims">
            <column name="id" valueSequenceNext="type_of_sample_seq"/>
            <column name="description" value="FFPE tissue block"/>
            <column name="domain" value="H"/>
            <column name="lastupdated" valueComputed="now()"/>
            <column name="local_abbrev" value="FFPE"/>
            <column name="is_active" value="Y"/>
            <column name="sort_order" valueNumeric="1"/>
            <column name="name_localization_id" valueComputed="(SELECT id FROM clinlims.localization WHERE english = 'FFPE tissue block' AND description = 'sampleType name')"/>
        </insert>
    </changeSet>

