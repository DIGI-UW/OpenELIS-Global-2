            <column name="vial_size_ml" type="DECIMAL(6,2)"/>
            <column name="fill_volume_ml" type="DECIMAL(6,3)"/>
            <column name="vial_count" type="INTEGER"/>
            <column name="cap_type" type="VARCHAR(100)"/>
            <column name="label_type" type="VARCHAR(100)"/>
            <column name="label_content" type="TEXT"/>
            <column name="storage_temperature_celsius" type="DECIMAL(6,2)"/>
            <column name="storage_location" type="VARCHAR(255)"/>
            <column name="expiry_date" type="DATE"/>
            <column name="package_integrity_check" type="VARCHAR(20)"/>
            <column name="final_titer_verification" type="VARCHAR(100)"/>
            <column name="sterility_test_result" type="VARCHAR(20)"/>
            <column name="endotoxin_test_result" type="VARCHAR(20)"/>
            <column name="packaging_date" type="TIMESTAMP"/>
            <column name="packaged_by" type="INTEGER"/>
            <column name="qc_checked_by" type="INTEGER"/>
            <column name="released_by" type="INTEGER"/>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="${now}"/>
            <column name="notes" type="TEXT"/>
        </createTable>

        <addForeignKeyConstraint constraintName="fk_packaging_packaged_by"
                               baseTableSchemaName="clinlims" baseTableName="virus_culture_packaging" baseColumnNames="packaged_by"
                               referencedTableSchemaName="clinlims" referencedTableName="system_user" referencedColumnNames="id"/>

        <addForeignKeyConstraint constraintName="fk_packaging_qc_checked_by"
                               baseTableSchemaName="clinlims" baseTableName="virus_culture_packaging" baseColumnNames="qc_checked_by"
                               referencedTableSchemaName="clinlims" referencedTableName="system_user" referencedColumnNames="id"/>

        <addForeignKeyConstraint constraintName="fk_packaging_released_by"
                               baseTableSchemaName="clinlims" baseTableName="virus_culture_packaging" baseColumnNames="released_by"
                               referencedTableSchemaName="clinlims" referencedTableName="system_user" referencedColumnNames="id"/>

        <createIndex tableName="virus_culture_packaging" schemaName="clinlims" indexName="idx_packaging_final_batch">
            <column name="final_batch_id"/>
        </createIndex>
    </changeSet>

