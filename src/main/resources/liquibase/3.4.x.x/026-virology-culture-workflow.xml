    <!-- FHIR UUID COLUMN ADDITION (for existing installations)  -->
    <!-- Add missing fhir_uuid column to virus_culture_batch     -->
    <!-- ======================================================== -->
    <changeSet id="add-virus-culture-batch-fhir-uuid" author="openelis-virology">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="virus_culture_batch" schemaName="clinlims"/>
                <not>
                    <columnExists tableName="virus_culture_batch" columnName="fhir_uuid" schemaName="clinlims"/>
                </not>
            </and>
        </preConditions>
        <comment>Add missing fhir_uuid column to virus_culture_batch table for existing installations</comment>

        <!-- Add the fhir_uuid column -->
        <addColumn tableName="virus_culture_batch" schemaName="clinlims">
            <column name="fhir_uuid" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Generate UUIDs for existing records -->
        <sql>
            UPDATE clinlims.virus_culture_batch
            SET fhir_uuid = gen_random_uuid()
            WHERE fhir_uuid IS NULL;
        </sql>

        <!-- Make the column non-nullable and unique after populating existing records -->
        <addNotNullConstraint tableName="virus_culture_batch" columnName="fhir_uuid" schemaName="clinlims"/>
        <addUniqueConstraint tableName="virus_culture_batch" columnNames="fhir_uuid" schemaName="clinlims" constraintName="uk_virus_culture_batch_fhir_uuid"/>
    </changeSet>

