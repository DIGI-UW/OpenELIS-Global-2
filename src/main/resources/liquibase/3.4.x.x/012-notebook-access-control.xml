<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="now" value="now()" dbms="postgresql"/>

    <!-- ======================================================== -->
    <!-- NOTEBOOK ACCESS CONTROL FEATURE -->
    <!-- Implements location-based access control for notebooks -->
    <!-- - Templates can be assigned to multiple organizations -->
    <!-- - Templates define which roles can create/edit entries -->
    <!-- - Entries are tied to a primary organization (immutable) -->
    <!-- - Entries inherit accessible organizations from template -->
    <!-- ======================================================== -->

    <!-- ======================================================== -->
    <!-- 1. NOTEBOOK_ORGANIZATIONS junction table -->
    <!-- Links notebook templates to organizations that can use them -->
    <!-- ======================================================== -->
    <changeSet id="create-notebook-organizations-table" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="notebook_organizations" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating NOTEBOOK_ORGANIZATIONS junction table for template-organization relationships.</comment>
        <createTable tableName="notebook_organizations">
            <column name="notebook_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="organization_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
            tableName="notebook_organizations"
            columnNames="notebook_id, organization_id"
            constraintName="pk_notebook_organizations"/>
        <addForeignKeyConstraint
            baseTableName="notebook_organizations"
            baseColumnNames="notebook_id"
            referencedTableName="notebook"
            referencedColumnNames="id"
            constraintName="fk_norg_notebook"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="notebook_organizations"
            baseColumnNames="organization_id"
            referencedTableName="organization"
            referencedColumnNames="id"
            constraintName="fk_norg_organization"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Index for querying notebooks by organization -->
    <changeSet id="add-notebook-organizations-indexes" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_organizations" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for notebook_organizations table.</comment>
        <createIndex tableName="notebook_organizations" indexName="idx_norg_notebook">
            <column name="notebook_id"/>
        </createIndex>
        <createIndex tableName="notebook_organizations" indexName="idx_norg_organization">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

    <!-- ======================================================== -->
    <!-- 2. NOTEBOOK_ALLOWED_ROLES table -->
    <!-- Defines which roles can create/edit entries for a template -->
    <!-- ======================================================== -->
    <changeSet id="create-notebook-allowed-roles-table" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="notebook_allowed_roles" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating NOTEBOOK_ALLOWED_ROLES table for template role restrictions.</comment>
        <createTable tableName="notebook_allowed_roles">
            <column name="notebook_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
            tableName="notebook_allowed_roles"
            columnNames="notebook_id, role"
            constraintName="pk_notebook_allowed_roles"/>
        <addForeignKeyConstraint
            baseTableName="notebook_allowed_roles"
            baseColumnNames="notebook_id"
            referencedTableName="notebook"
            referencedColumnNames="id"
            constraintName="fk_nar_notebook"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Index for querying roles by notebook -->
    <changeSet id="add-notebook-allowed-roles-index" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_allowed_roles" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating index for notebook_allowed_roles table.</comment>
        <createIndex tableName="notebook_allowed_roles" indexName="idx_nar_notebook">
            <column name="notebook_id"/>
        </createIndex>
    </changeSet>

    <!-- ======================================================== -->
    <!-- 3. Add organization_id to NOTEBOOK_ENTRY table -->
    <!-- Primary organization for the entry (immutable after creation) -->
    <!-- ======================================================== -->
    <changeSet id="add-organization-to-notebook-entry" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_entry" schemaName="clinlims"/>
            <not>
                <columnExists tableName="notebook_entry" columnName="organization_id" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Adding organization_id column to notebook_entry for primary location.</comment>
        <addColumn tableName="notebook_entry">
            <column name="organization_id" type="INTEGER">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint
            baseTableName="notebook_entry"
            baseColumnNames="organization_id"
            referencedTableName="organization"
            referencedColumnNames="id"
            constraintName="fk_ne_organization"/>
    </changeSet>

    <!-- Index for querying entries by organization -->
    <changeSet id="add-notebook-entry-organization-index" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_entry" schemaName="clinlims"/>
            <columnExists tableName="notebook_entry" columnName="organization_id" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating index for notebook_entry organization_id.</comment>
        <createIndex tableName="notebook_entry" indexName="idx_ne_organization">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

    <!-- ======================================================== -->
    <!-- 4. NOTEBOOK_ENTRY_ORGANIZATIONS junction table -->
    <!-- Organizations with access to an entry (inherited from template) -->
    <!-- ======================================================== -->
    <changeSet id="create-notebook-entry-organizations-table" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="notebook_entry_organizations" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating NOTEBOOK_ENTRY_ORGANIZATIONS junction table for entry access control.</comment>
        <createTable tableName="notebook_entry_organizations">
            <column name="notebook_entry_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="organization_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
            tableName="notebook_entry_organizations"
            columnNames="notebook_entry_id, organization_id"
            constraintName="pk_notebook_entry_organizations"/>
        <addForeignKeyConstraint
            baseTableName="notebook_entry_organizations"
            baseColumnNames="notebook_entry_id"
            referencedTableName="notebook_entry"
            referencedColumnNames="id"
            constraintName="fk_neorg_notebook_entry"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="notebook_entry_organizations"
            baseColumnNames="organization_id"
            referencedTableName="organization"
            referencedColumnNames="id"
            constraintName="fk_neorg_organization"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Indexes for entry organizations -->
    <changeSet id="add-notebook-entry-organizations-indexes" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_entry_organizations" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for notebook_entry_organizations table.</comment>
        <createIndex tableName="notebook_entry_organizations" indexName="idx_neorg_entry">
            <column name="notebook_entry_id"/>
        </createIndex>
        <createIndex tableName="notebook_entry_organizations" indexName="idx_neorg_organization">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

    <!-- ======================================================== -->
    <!-- 5. NOTEBOOK_DEPARTMENTS junction table -->
    <!-- Links notebook templates to departments (test sections) that can use them -->
    <!-- ======================================================== -->
    <changeSet id="create-notebook-departments-table" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="notebook_departments" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Creating NOTEBOOK_DEPARTMENTS junction table for template-department relationships.</comment>
        <createTable tableName="notebook_departments">
            <column name="notebook_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="test_section_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
            tableName="notebook_departments"
            columnNames="notebook_id, test_section_id"
            constraintName="pk_notebook_departments"/>
        <addForeignKeyConstraint
            baseTableName="notebook_departments"
            baseColumnNames="notebook_id"
            referencedTableName="notebook"
            referencedColumnNames="id"
            constraintName="fk_ndept_notebook"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="notebook_departments"
            baseColumnNames="test_section_id"
            referencedTableName="test_section"
            referencedColumnNames="id"
            constraintName="fk_ndept_test_section"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Index for querying notebooks by department -->
    <changeSet id="add-notebook-departments-indexes" author="openelis-access-control">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notebook_departments" schemaName="clinlims"/>
        </preConditions>
        <comment>Creating indexes for notebook_departments table.</comment>
        <createIndex tableName="notebook_departments" indexName="idx_ndept_notebook">
            <column name="notebook_id"/>
        </createIndex>
        <createIndex tableName="notebook_departments" indexName="idx_ndept_test_section">
            <column name="test_section_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
