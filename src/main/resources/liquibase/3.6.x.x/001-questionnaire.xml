<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="questionnaire-001-create-questionnaire" author="elijah">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="questionnaire"/>
            </not>
        </preConditions>

        <createTable tableName="questionnaire">

            <column name="id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="fhir_uuid" type="UUID">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="code" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>

            <column name="has_item" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="parent_questionnaire_id" type="VARCHAR(20)"/>

            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(255)"/>

            <column name="questionnaire_name" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>

            <column name="approval_date" type="DATE"/>

            <column name="effective_date" type="DATE"/>

            <column name="last_reviewed" type="DATE"/>

            <column name="status_id" type="VARCHAR(10)"/>

            <column name="purpose" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="sys_user_id" type="VARCHAR(36)" />

            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex tableName="questionnaire" indexName="idx_questionnaire_fhir_uuid">
            <column name="fhir_uuid"/>
        </createIndex>

        <createIndex tableName="questionnaire" indexName="idx_questionnaire_parent">
            <column name="parent_questionnaire_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="questionnaire"/>
        </rollback>

    </changeSet>

    <changeSet id="questionnaire-002-create-questionnaire-item" author="elijah">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="questionnaire_item"/>
            </not>
        </preConditions>

        <createTable tableName="questionnaire_item">

            <column name="id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="questionnaire_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="link_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="text" type="TEXT"/>

            <column name="item_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>

            <column name="required" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="repeats" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="item_order" type="INT"/>

            <column name="parent_item_id" type="VARCHAR(20)"/>

            <column name="sys_user_id" type="VARCHAR(36)" />

            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex tableName="questionnaire_item" indexName="idx_q_item_q">
            <column name="questionnaire_id"/>
        </createIndex>

        <createIndex tableName="questionnaire_item" indexName="idx_q_item_link">
            <column name="link_id"/>
        </createIndex>

        <createIndex tableName="questionnaire_item" indexName="idx_q_item_parent">
            <column name="parent_item_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="questionnaire_item"/>
        </rollback>

    </changeSet>

    <changeSet id="questionnaire-003-create-answer-option" author="elijah">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="questionnaire_answer_option"/>
            </not>
        </preConditions>

        <createTable tableName="questionnaire_answer_option">

            <column name="id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="questionnaire_item_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="value_code" type="VARCHAR(100)"/>

            <column name="display_name" type="VARCHAR(255)"/>

            <column name="initial_selected" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="sys_user_id" type="VARCHAR(36)" />

            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex tableName="questionnaire_answer_option" indexName="idx_ao_item">
            <column name="questionnaire_item_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="questionnaire_answer_option"/>
        </rollback>

    </changeSet>

    <changeSet id="questionnaire-004-create-item-initial" author="elijah">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="questionnaire_item_initial"/>
            </not>
        </preConditions>

        <createTable tableName="questionnaire_item_initial">

            <column name="id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="questionnaire_item_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="value_string" type="VARCHAR(1000)"/>

            <column name="value_boolean" type="BOOLEAN"/>

            <column name="value_integer" type="INT"/>

            <column name="value_decimal" type="DECIMAL(18,2)"/>

            <column name="value_date" type="DATE"/>

            <column name="sys_user_id" type="VARCHAR(36)" />

            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex tableName="questionnaire_item_initial" indexName="idx_q_init_item">
            <column name="questionnaire_item_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="questionnaire_item_initial"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
