<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="20250825-01-create-result-file-table" author="elia">
        <createSequence sequenceName="result_file_seq" startValue="1" incrementBy="1"/>

        <createTable tableName="result_file">
            <column name="id" type="NUMERIC(10,0)" defaultValueSequenceNext="result_file_seq">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="file_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="file_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_content" type="bytea">
                <constraints nullable="false"/>
            </column>
            <column name="uploaded_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Explicitly add unique constraint for the foreign key reference -->
        <addUniqueConstraint tableName="result_file"
                            columnNames="id"
                            constraintName="uk_result_file_id"/>
    </changeSet>

    <changeSet id="20250825-02-add-resultfile-to-analysis" author="elia">
        <addColumn tableName="analysis">
            <column name="result_file_id" type="NUMERIC(10,0)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint baseTableName="analysis"
                                 baseColumnNames="result_file_id"
                                 referencedTableName="result_file"
                                 referencedColumnNames="id"
                                 constraintName="fk_analysis_resultfile"
                                 onDelete="SET NULL"/>

        <addUniqueConstraint tableName="analysis"
                            columnNames="result_file_id"
                            constraintName="uq_analysis_result_file"/>
    </changeSet>

</databaseChangeLog>
