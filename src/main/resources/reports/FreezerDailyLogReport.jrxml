<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="FreezerDailyLogReport"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="freezer-daily-log-report">

    <!-- Parameters -->
    <parameter name="reportTitle" class="java.lang.String"/>
    <parameter name="labName" class="java.lang.String"/>
    <parameter name="startDate" class="java.lang.String"/>
    <parameter name="endDate" class="java.lang.String"/>
    <parameter name="complianceFooter" class="java.lang.String"/>
    <parameter name="leftHeaderImage" class="java.io.InputStream"/>

    <!-- Fields from FreezerReadingReportData bean -->
    <field name="freezerId" class="java.lang.String"/>
    <field name="freezerName" class="java.lang.String"/>
    <field name="location" class="java.lang.String"/>
    <field name="timestamp" class="java.lang.String"/>
    <field name="temperatureFormatted" class="java.lang.String"/>
    <field name="humidityFormatted" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="minThreshold" class="java.lang.String"/>
    <field name="maxThreshold" class="java.lang.String"/>

    <!-- Page Header -->
    <pageHeader>
        <band height="100">
            <textField>
                <reportElement x="0" y="0" width="802" height="20" uuid="lab-name"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{labName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="25" width="802" height="20" uuid="report-title"/>
                <textElement textAlignment="Center">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="50" width="802" height="20" uuid="date-range"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["Date Range: " + $P{startDate} + " to " + $P{endDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="650" y="75" width="150" height="20" uuid="print-date"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Printed: " + new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm").format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <!-- Column Header -->
    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="80" height="30" uuid="header-freezer-id"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Freezer ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="80" y="0" width="120" height="30" uuid="header-freezer-name"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Freezer Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="100" height="30" uuid="header-location"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Location]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="140" height="30" uuid="header-timestamp"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Timestamp]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="90" height="30" uuid="header-temperature"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Temperature]]></text>
            </staticText>
            <staticText>
                <reportElement x="530" y="0" width="90" height="30" uuid="header-humidity"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Humidity]]></text>
            </staticText>
            <staticText>
                <reportElement x="620" y="0" width="90" height="30" uuid="header-status"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement x="710" y="0" width="92" height="30" uuid="header-thresholds"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement>
                <text><![CDATA[Thresholds]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detail Band -->
    <detail>
        <band height="20">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="80" height="20" uuid="data-freezer-id"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{freezerId}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="80" y="0" width="120" height="20" uuid="data-freezer-name"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{freezerName}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="200" y="0" width="100" height="20" uuid="data-location"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Left" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{location}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="300" y="0" width="140" height="20" uuid="data-timestamp"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{timestamp}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="440" y="0" width="90" height="20" uuid="data-temperature"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{temperatureFormatted}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="530" y="0" width="90" height="20" uuid="data-humidity"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{humidityFormatted}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="620" y="0" width="90" height="20" uuid="data-status"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="710" y="0" width="92" height="20" uuid="data-thresholds"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{minThreshold} + " - " + $F{maxThreshold}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Page Footer -->
    <pageFooter>
        <band height="40">
            <textField>
                <reportElement x="0" y="0" width="802" height="20" uuid="compliance-footer"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{complianceFooter}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="200" height="20" uuid="page-number"/>
                <textElement textAlignment="Left"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
