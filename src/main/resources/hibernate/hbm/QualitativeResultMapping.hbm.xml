<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <!-- QualitativeResultMapping: Maps analyzer-specific qualitative values
        to OpenELIS canonical codes. XML-only mapping to match analyzer module pattern. -->
    <class
        name="org.openelisglobal.analyzer.valueholder.QualitativeResultMapping"
        table="qualitative_result_mapping" optimistic-lock="version"
        dynamic-update="true">

        <id name="id" type="java.lang.String">
            <column name="id" length="36" />
            <generator class="assigned" />
        </id>
        <version name="lastupdated" column="last_updated"
            type="timestamp" access="field" />

        <property name="analyzerFieldId" type="java.lang.String">
            <column name="analyzer_field_id" not-null="true" length="36" />
        </property>

        <property name="analyzerValue" type="java.lang.String">
            <column name="analyzer_value" not-null="true" length="100" />
        </property>

        <property name="openelisCode" type="java.lang.String">
            <column name="openelis_code" not-null="true" length="100" />
        </property>

        <property name="isDefault" type="java.lang.Boolean">
            <column name="is_default" not-null="true" />
        </property>
    </class>
</hibernate-mapping>
