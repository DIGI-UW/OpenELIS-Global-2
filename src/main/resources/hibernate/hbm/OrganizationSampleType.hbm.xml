<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping
    package="org.openelisglobal.organization.valueholder">
    <class name="OrganizationSampleType"
        table="ORGANIZATION_SAMPLE_TYPE" optimistic-lock="version"
        dynamic-update="true">
        <id name="id"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="ID" precision="10" scale="0" />
            <generator
                class="org.openelisglobal.hibernate.resources.StringSequenceGenerator">
                <param name="sequence_name">ORGANIZATION_SAMPLE_TYPE_SEQ</param>
            </generator>
        </id>

        <version name="lastupdated" column="LASTUPDATED"
            type="timestamp" access="field" />

        <property name="organizationId"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="ORG_ID" precision="10" scale="0" not-null="true" />
        </property>

        <property name="sampleTypeId"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="SAMPLE_TYPE_ID" precision="10" scale="0"
                not-null="true" />
        </property>

        <property name="isActive" type="yes_no">
            <column name="IS_ACTIVE" length="1" not-null="true" />
        </property>

        <property name="sortOrder" type="java.lang.Integer">
            <column name="SORT_ORDER" />
        </property>
    </class>
</hibernate-mapping>
