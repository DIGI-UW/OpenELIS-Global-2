<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping
    package="org.openelisglobal.panellabunit.valueholder">
    <class name="PanelLabUnit" table="PANEL_LAB_UNIT"
        optimistic-lock="version" dynamic-update="true">
        <id name="id"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="ID" precision="10" scale="0" />
            <generator
                class="org.openelisglobal.hibernate.resources.StringSequenceGenerator">
                <param name="sequence_name">PANEL_LAB_UNIT_SEQ</param>
            </generator>
        </id>

        <property name="panelId"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="PANEL_ID" precision="10" scale="0" />
        </property>

        <property name="labUnitId"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="LAB_UNIT_ID" precision="10" scale="0" />
        </property>
    </class>
</hibernate-mapping>
