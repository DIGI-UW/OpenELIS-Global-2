<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="org.openelisglobal.storage.valueholder.StoragePosition"
        table="STORAGE_POSITION" optimistic-lock="version" dynamic-update="true">
        <id name="id"
            type="org.openelisglobal.hibernate.resources.usertype.LIMSStringNumberUserType">
            <column name="ID" precision="10" scale="0" />
            <generator
                class="org.openelisglobal.hibernate.resources.StringSequenceGenerator">
                <param name="sequence_name">storage_position_seq</param>
            </generator>
        </id>
        <version name="lastupdated" column="LASTUPDATED"
            type="timestamp" access="field" />

        <property name="fhirUuid" type="java.util.UUID">
            <column name="FHIR_UUID" not-null="true" unique="true" />
        </property>
        <property name="coordinate" type="java.lang.String">
            <column name="COORDINATE" length="50" not-null="true" />
        </property>
        <property name="rowIndex" type="java.lang.Integer">
            <column name="ROW_INDEX" />
        </property>
        <property name="columnIndex" type="java.lang.Integer">
            <column name="COLUMN_INDEX" />
        </property>
        <property name="occupied" type="java.lang.Boolean">
            <column name="OCCUPIED" not-null="true" />
        </property>
        <many-to-one name="parentRack"
            class="org.openelisglobal.storage.valueholder.StorageRack" 
            fetch="select" lazy="false">
            <column name="PARENT_RACK_ID" precision="10" scale="0" not-null="true" />
        </many-to-one>
    </class>
</hibernate-mapping>

