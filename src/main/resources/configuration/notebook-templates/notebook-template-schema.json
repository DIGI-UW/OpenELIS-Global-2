{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openelis-global.org/schemas/notebook-template.schema.json",
  "title": "Notebook Template",
  "description": "Schema for OpenELIS-Global notebook template configuration files loaded by NotebookTemplateConfigurationHandler",
  "type": "object",
  "required": ["title", "pages"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Unique template title. Used as the lookup key — if a template with this title exists it will be updated."
    },
    "workflowType": {
      "type": "string",
      "description": "Frontend workflow routing key (e.g. 'tuberculosis', 'gbd'). Used by PAGE_TYPE_REGISTRY."
    },
    "departments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Test section names to link this template to. Warns if a name is not found in the DB."
    },
    "objective": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "SUBMITTED", "FINALIZED", "LOCKED", "ARCHIVED", "ACTIVE"],
      "default": "ACTIVE",
      "description": "Template status. Defaults to ACTIVE if omitted or invalid."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order"],
        "additionalProperties": false,
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based page order within the template. Must be unique within the template (validation enforced at startup; duplicates will cause configuration to be rejected with an error)."
          },
          "title": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "description": "Page-level configuration object. Persisted to notebook_page.data JSONB column at runtime. Configuration can be updated without schema migration.",
            "additionalProperties": true,
            "properties": {
              "manifestColumns": {
                "type": "array",
                "description": "Column definitions for generic_sample_reception manifest import",
                "items": {
                  "type": "object",
                  "required": ["csvHeader", "field", "label"],
                  "additionalProperties": true,
                  "properties": {
                    "csvHeader": {
                      "type": "string"
                    },
                    "field": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean",
                      "default": false
                    },
                    "description": {
                      "type": "string"
                    },
                    "example": {
                      "type": "string"
                    },
                    "aliases": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "category": {
                      "type": "string"
                    },
                    "validValues": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "When present, TypeOfSample DB lookup is skipped and validation is done against this list"
                    }
                  }
                }
              },
              "columns": {
                "type": "object"
              },
              "sampleTypesEndpoint": {
                "type": "string"
              },
              "sampleCategoriesEndpoint": {
                "type": "string"
              },
              "autoGeneratedFields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["key", "label"],
                  "additionalProperties": true,
                  "properties": {
                    "key": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
